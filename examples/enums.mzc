// enums (tagged unions) + exhaustive match
enum Shape {
  Circle(f64),
  Rect(f64, f64),
  Unit,
}

function size(s: Shape): f64 {
  match s {
    Circle(r) => { return r * r; }
    Rect(w, h) => { return w * h; }
    Unit => { return 0.0; }
  }
  return 0.0;
}

function main() {
  stdout.println(size(Circle(2.0)));      // 4
  stdout.println(size(Rect(3.0, 4.0)));   // 12
  stdout.println(size(Unit));             // 0
}
