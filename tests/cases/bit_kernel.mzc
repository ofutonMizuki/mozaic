// Bitwise ops inside a GPU kernel (CPU golden; prove.sh checks GPU==CPU). Metal emits native & | ^ ~ << >>.
kernel bitk(inp: Buffer<u32>, out: Buffer<u32>, n: u32) {
  let gid: u32 = grid.x;
  if (gid < n) {
    let v: u32 = inp[gid];
    out[gid] = ((v << 2) | (v >> 1)) ^ (~v & 15);
  }
}
function main() {
  let n: u32 = 8;
  let inp: Buffer<u32> = Buffer.shared(n);
  let out: Buffer<u32> = Buffer.shared(n);
  let i: u32 = 0;
  while (i < n) { inp[i] = i +% 1; i = i +% 1; }
  let dev: Device = Device.gpu;
  let j: Job = dev.launch(bitk, n, &inp, &mut out, n);
  j.await();
  let k: u32 = 0;
  while (k < n) { stdout.println(out[k]); k = k +% 1; }
}
