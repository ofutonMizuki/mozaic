// mozc — a mozaic-subset compiler WRITTEN IN MOZAIC (M7 self-host).
// Reads a mozaic program from stdin, compiles it to standalone C++ on stdout.
// Subset ("μmozaic"): functions + recursion; int/bool/str/char; structs with methods (&self/
// &mut self); enums + match (tagged unions); fixed arrays [T;N]; `as` casts; let / assignment to
// any lvalue (name/field/index) / return / if-else-if / while; arithmetic (+ - * / %), comparison,
// logical (&& || !); calls; stdout.println. (Struct-literal fields must be written in declared
// order.) Pipeline mirrors the real compiler: lex -> parse (Box-recursive AST + Vec lists +
// struct-method parser) -> emit C++. Verified end-to-end (builds with clang++ and runs correctly)
// on recursive / struct+method / string / char / enum-match / array / mutation programs.

// ---- tokens ----
const KNUM: i32 = 0;     // integer literal (ival)
const KWORD: i32 = 1;    // identifier or keyword (text)
const KOP: i32 = 2;      // operator / punctuation (text)
const KEOF: i32 = 3;     // end of input
const KSTR: i32 = 4;     // string literal (text = raw content)
const KCHAR: i32 = 5;    // char literal (ival = codepoint)
const KTMPL: i32 = 6;    // template string (text = raw content with ${...} and escapes kept)
const KFLOAT: i32 = 7;   // float literal (text = the literal, e.g. "3.9", "1e9")
struct Token { kind: i32; text: str; ival: i64; }

// ---- AST ----
enum Expr {
  Num(i64),
  FloatLit(str),                     // 3.9 / 1e9 (emitted verbatim)
  Var(str),
  Bin(str, Box<Expr>, Box<Expr>),   // operator text, left, right
  Not(Box<Expr>),
  Call(str, Vec<Box<Expr>>),         // function call, OR enum-variant construction (resolved at emit)
  StrLit(str),                       // "..."
  CharLit(i64),                      // 'a' -> codepoint
  Cast(Box<Expr>, str),              // e as T
  BoolLit(bool),                     // true / false
  Field(Box<Expr>, str),             // e.field  (.len -> .size())
  Index(Box<Expr>, Box<Expr>),       // e[i]
  Borrow(bool, Box<Expr>),           // &mut e (true) / &e (false)  (erased in emit; C++ refs bind to lvalues)
  ArrLit(Vec<Box<Expr>>),            // [a, b, c]  (only as an initializer)
  StructLit(str, Vec<Box<Expr>>),    // Name { f: v, ... } — values in declared field order
  MethodCall(Box<Expr>, str, Vec<Box<Expr>>),   // obj.method(args)
  Template(Vec<str>, Vec<Box<Expr>>),           // `lit ${e} lit` ; strings.len == exprs.len + 1
  Some(Box<Expr>),                              // some(x) -> { x }
  NoneLit,                                      // none -> {}
  OkE(Box<Expr>),                               // Ok(x)  -> { true, x }
  ErrE(Box<Expr>),                              // Err(e) -> { false, {}, e }
  OrElse(Box<Expr>, Box<Expr>),                 // a ?? b -> (a).value_or(b)
  SpawnExpr(str, Vec<Box<Expr>>),               // spawn f(args) — fn name + args (only as a let value)
  TryQ(Box<Expr>),                              // e? -> propagate none/Err (statement-expr)
  TryCast(Box<Expr>, str),                      // e as? T -> mz::checked_cast<T>(e)
  Comptime(Box<Expr>),                          // comptime e -> e (build-time; may only read consts/literals)
}
enum Stmt {
  Let(str, str, Box<Expr>, bool),    // name, mozaic type, value, isConst (declared with `const`)
  Assign(Box<Expr>, Box<Expr>),      // lvalue = value  (name / e.field / a[i])
  Ret(Box<Expr>),                    // return value
  RetVoid,                           // return; (no value)
  Print(Box<Expr>),                  // stdout.println(value)
  ExprS(Box<Expr>),                  // expression statement (e.g. a call)
  If(Box<Expr>, Vec<Stmt>, Vec<Stmt>),
  While(Box<Expr>, Vec<Stmt>),
  Match(Box<Expr>, Vec<Arm>),
  Defer(Vec<Stmt>),                  // defer { ... } / defer stmt -> MZ_DEFER(...)
  Scope(Vec<Stmt>),                  // scope { spawn f(..); ... } -> thread vector, join all at block end
  ForOf(str, Box<Expr>, Vec<Stmt>),  // for (const x of iter) { ... } -> range-for
  Shared(str, str),                  // shared name: T; (threadgroup memory -> kernel param + per-group decl)
}
struct Arm { variant: str; bindings: Vec<str>; body: Vec<Stmt>; }
struct Param { name: str; ty: str; }
struct Method { name: str; isMut: bool; params: Vec<Param>; ret: str; body: Vec<Stmt>; }
struct Func { name: str; tparams: Vec<str>; params: Vec<Param>; ret: str; body: Vec<Stmt>; isKernel: bool; }
struct StructDef { name: str; tparams: Vec<str>; fields: Vec<Param>; methods: Vec<Method>; }
struct ConstD { name: str; ty: str; value: Box<Expr>; }
struct Variant { name: str; payloads: Vec<str>; }   // payload type names ([] = unit variant)
struct EnumDef { name: str; variants: Vec<Variant>; }
struct VInfo { found: bool; enumName: str; tag: i32; payloads: Vec<str>; }   // result of a variant lookup

// ---- lexer ----
function isDigit(c: char): bool { return c >= '0' && c <= '9'; }
function isAlpha(c: char): bool { return (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || c == '_'; }
function isSpace(c: char): bool { return c == ' ' || c == '\n' || c == '\t' || c == '\r'; }

function lex(src: str): Vec<Token> {
  let toks: Vec<Token> = Vec.new();
  let i: u32 = 0;
  let n: u32 = src.len;
  while (i < n) {
    let c: char = src[i];
    if (c == '/' && i +% 1 < n && src[i +% 1] == '/') {        // line comment
      while (i < n && src[i] != '\n') { i = i +% 1; }
    } else if (c == '/' && i +% 1 < n && src[i +% 1] == '*') {  // block comment
      i = i +% 2;
      while (i +% 1 < n && !(src[i] == '*' && src[i +% 1] == '/')) { i = i +% 1; }
      i = i +% 2;
    } else if (isSpace(c)) {
      i = i +% 1;
    } else if (isDigit(c)) {
      let ns: str = "";
      let isF: bool = false;
      while (i < n && isDigit(src[i])) { ns = ns + format(src[i]); i = i +% 1; }
      if (i +% 1 < n && src[i] == '.' && isDigit(src[i +% 1])) {   // fractional part
        isF = true; ns = ns + format(src[i]); i = i +% 1;
        while (i < n && isDigit(src[i])) { ns = ns + format(src[i]); i = i +% 1; }
      }
      if (i < n && (src[i] == 'e' || src[i] == 'E')) {             // exponent
        isF = true; ns = ns + format(src[i]); i = i +% 1;
        if (i < n && (src[i] == '+' || src[i] == '-')) { ns = ns + format(src[i]); i = i +% 1; }
        while (i < n && isDigit(src[i])) { ns = ns + format(src[i]); i = i +% 1; }
      }
      if (isF) { toks.push(Token { kind: KFLOAT, text: ns, ival: 0 }); }
      else {
        let v: i64 = 0;
        let k: u32 = 0;
        while (k < ns.len) { v = v *% 10 +% ((ns[k] as u32) as i64) -% (('0' as u32) as i64); k = k +% 1; }
        toks.push(Token { kind: KNUM, text: "", ival: v });
      }
    } else if (isAlpha(c)) {
      let w: str = "";
      while (i < n && (isAlpha(src[i]) || isDigit(src[i]))) { w = w + format(src[i]); i = i +% 1; }
      toks.push(Token { kind: KWORD, text: w, ival: 0 });
    } else if (c == '"') {           // string literal: keep raw content (escapes pass through to C++)
      i = i +% 1;
      let s: str = "";
      while (i < n && src[i] != '"') {
        if (src[i] == '\\') { s = s + format(src[i]); i = i +% 1; if (i < n) { s = s + format(src[i]); i = i +% 1; } }
        else { s = s + format(src[i]); i = i +% 1; }
      }
      i = i +% 1;
      toks.push(Token { kind: KSTR, text: s, ival: 0 });
    } else if (c == '\'') {          // char literal -> codepoint
      i = i +% 1;
      let cp: i64 = 0;
      if (src[i] == '\\') {
        i = i +% 1;
        let e: char = src[i];
        if (e == 'n') { cp = 10; } else if (e == 't') { cp = 9; } else if (e == 'r') { cp = 13; } else if (e == '0') { cp = 0; } else { cp = (e as u32) as i64; }
        i = i +% 1;
      } else {
        cp = (src[i] as u32) as i64;
        i = i +% 1;
      }
      i = i +% 1;                    // closing quote
      toks.push(Token { kind: KCHAR, text: "", ival: cp });
    } else if (c == '`') {           // template string -> raw content (escapes & ${...} kept verbatim)
      i = i +% 1;
      let raw: str = "";
      let brace: i32 = 0;
      let done: bool = false;
      while (i < n && !done) {
        let d: char = src[i];
        if (brace == 0 && d == '`') { i = i +% 1; done = true; }
        else if (brace == 0 && d == '\\') { raw = raw + format(d); i = i +% 1; if (i < n) { raw = raw + format(src[i]); i = i +% 1; } }
        else if (brace == 0 && d == '$' && i +% 1 < n && src[i +% 1] == '{') { brace = 1; raw = raw + "${"; i = i +% 2; }
        else if (brace > 0) {
          if (d == '{') { brace = brace +% 1; } else if (d == '}') { brace = brace -% 1; }
          raw = raw + format(d); i = i +% 1;
        } else { raw = raw + format(d); i = i +% 1; }
      }
      toks.push(Token { kind: KTMPL, text: raw, ival: 0 });
    } else {
      // two-character operators first
      let two: str = "";
      if (i +% 1 < n) { two = format(src[i]) + format(src[i +% 1]); }
      if (two == "==" || two == "!=" || two == "<=" || two == ">=" || two == "&&" || two == "||" || two == "=>" || two == "??"
          || two == "+%" || two == "-%" || two == "*%" || two == "+|" || two == "-|" || two == "*|") {
        toks.push(Token { kind: KOP, text: two, ival: 0 });
        i = i +% 2;
      } else {
        toks.push(Token { kind: KOP, text: format(c), ival: 0 });
        i = i +% 1;
      }
    }
  }
  toks.push(Token { kind: KEOF, text: "", ival: 0 });
  return toks;
}

// ---- parser (recursive descent) ----
struct Parser {
  toks: Vec<Token>;
  pos: u32;
  structs: Vec<StructDef>;
  enums: Vec<EnumDef>;
  consts: Vec<ConstD>;
  noStruct: bool;          // suppress `Name { ... }` struct-literal parsing (e.g. for a match scrutinee)
  function kind(&self): i32 { return self.toks[self.pos].kind; }
  function text(&self): str { return self.toks[self.pos].text; }
  function ival(&self): i64 { return self.toks[self.pos].ival; }
  function adv(&mut self) { self.pos = self.pos +% 1; }
  // Match an operator/keyword token by text (NOT a string/char/template literal of the same text).
  function at(&self, t: str): bool { let k: i32 = self.kind(); return (k == KOP || k == KWORD) && self.text() == t; }
  function eat(&mut self, t: str) {
    if (self.at(t)) { self.adv(); } else { abort(`parse: expected '${t}'`); }
  }
  function word(&mut self): str { let w: str = self.text(); self.adv(); return w; }
  function parseType(&mut self): str {   // returns a C++ type string directly
    let r: str = "";
    if (self.at("&")) {             // &T -> const T&  /  &mut T -> T&
      self.adv();
      let isMut: bool = false;
      if (self.at("mut")) { self.adv(); isMut = true; }
      let inner: str = self.parseType();
      if (isMut) { r = inner + "&"; } else { r = `const ${inner}&`; }
    } else if (self.at("[")) {
      self.adv();
      if (self.at("]")) { self.adv(); let el: str = self.parseType(); r = `mz::Slice<${el}>`; }   // []T slice
      else {
        let elem: str = self.parseType();
        self.eat(";");
        let nv: i64 = self.ival(); self.adv();
        self.eat("]");
        r = `std::array<${elem}, ${format(nv)}>`;
      }
    } else {
      let w: str = self.word();
      if (self.at("<")) {            // generic: Vec<T> / Box<T> / Map<K,V> / Result<T,E> / user Name<...>
        self.adv();
        let args: str = self.parseType();
        while (self.at(",")) { self.adv(); args = args + ", " + self.parseType(); }
        self.eat(">");
        if (w == "Vec") { r = `mz::Vec<${args}>`; }
        else if (w == "Box") { r = `mz::Box<${args}>`; }
        else if (w == "Map") { r = `mz::Map<${args}>`; }
        else if (w == "Result") { r = `mz::Result<${args}>`; }
        else if (w == "Atomic") { r = `std::atomic<${args}>`; }
        else if (w == "Arc") { r = `mz::Arc<${args}>`; }
        else if (w == "Mutex") { r = `mz::Mutex<${args}>`; }
        else if (w == "Channel") { r = `mz::Channel<${args}>`; }
        else if (w == "Buffer") { r = `mz::Buffer<${args}>`; }
        else if (w == "Task") { r = `mz::JoinFuture<${args}>`; }   // Task<R> result-returning task
        else { r = `${w}<${args}>`; }
      } else {
        let sd: str = simdCpp(w);                  // f32x4 / i32x4 -> mz::Simd<lane, N>
        if (sd != "") { r = sd; } else { r = mapType(w); }
      }
    }
    while (self.at("?")) { self.adv(); r = `std::optional<${r}>`; }   // T? -> std::optional<T>
    return r;
  }

  function parsePrimary(&mut self): Box<Expr> {
    if (self.kind() == KNUM) { let v: i64 = self.ival(); self.adv(); return Box.new(Num(v)); }
    if (self.kind() == KFLOAT) { let s: str = self.text(); self.adv(); return Box.new(FloatLit(s)); }
    if (self.kind() == KCHAR) { let cp: i64 = self.ival(); self.adv(); return Box.new(CharLit(cp)); }
    if (self.kind() == KSTR) { let s: str = self.text(); self.adv(); return Box.new(StrLit(s)); }
    if (self.kind() == KTMPL) { let raw: str = self.text(); self.adv(); return self.parseTemplate(raw); }
    if (self.at("(")) { self.adv(); let e: Box<Expr> = self.parseExpr(); self.eat(")"); return e; }
    if (self.at("[")) {                   // array literal [a, b, c]
      self.adv();
      let elems: Vec<Box<Expr>> = Vec.new();
      while (!self.at("]")) {
        elems.push(self.parseExpr());
        if (self.at(",")) { self.adv(); }
      }
      self.eat("]");
      return Box.new(ArrLit(elems));
    }
    if (self.kind() == KWORD) {
      if (self.at("true")) { self.adv(); return Box.new(BoolLit(true)); }
      if (self.at("false")) { self.adv(); return Box.new(BoolLit(false)); }
      if (self.at("spawn")) {                 // spawn f(args)
        self.adv();
        let fn: str = self.word();
        self.eat("(");
        let sargs: Vec<Box<Expr>> = Vec.new();
        if (!self.at(")")) {
          sargs.push(self.parseExpr());
          while (self.at(",")) { self.adv(); sargs.push(self.parseExpr()); }
        }
        self.eat(")");
        return Box.new(SpawnExpr(fn, sargs));
      }
      if (self.at("none")) { self.adv(); return Box.new(NoneLit); }
      if (self.at("some")) { self.adv(); self.eat("("); let x: Box<Expr> = self.parseExpr(); self.eat(")"); return Box.new(Some(x)); }
      if (self.at("Ok")) { self.adv(); self.eat("("); let x: Box<Expr> = self.parseExpr(); self.eat(")"); return Box.new(OkE(x)); }
      if (self.at("Err")) { self.adv(); self.eat("("); let x: Box<Expr> = self.parseExpr(); self.eat(")"); return Box.new(ErrE(x)); }
      let name: str = self.word();
      if (self.at("(")) {                 // function call / enum-variant construction
        self.adv();
        let args: Vec<Box<Expr>> = Vec.new();
        if (!self.at(")")) {
          args.push(self.parseExpr());
          while (self.at(",")) { self.adv(); args.push(self.parseExpr()); }
        }
        self.eat(")");
        return Box.new(Call(name, args));
      }
      if (self.at("{") && !self.noStruct) {   // struct literal Name { f: v, ... } (declared order)
        self.adv();
        let vals: Vec<Box<Expr>> = Vec.new();
        while (!self.at("}")) {
          self.word(); self.eat(":");           // field name discarded (values must be in declared order)
          vals.push(self.parseExpr());
          if (self.at(",")) { self.adv(); }
        }
        self.eat("}");
        return Box.new(StructLit(name, vals));
      }
      return Box.new(Var(name));
    }
    abort(`parse: unexpected token '${self.text()}' (kind ${self.kind()}) at ${self.pos}`);
    return Box.new(Num(0));
  }
  function parsePostfix(&mut self): Box<Expr> {
    let e: Box<Expr> = self.parsePrimary();
    while (self.at(".") || self.at("[") || self.at("?")) {
      if (self.at("?")) { self.adv(); e = Box.new(TryQ(e)); }      // e? -> propagate none/Err
      else if (self.at("[")) { self.adv(); let idx: Box<Expr> = self.parseExpr(); self.eat("]"); e = Box.new(Index(e, idx)); }
      else {
        self.adv();
        let m: str = self.word();
        if (self.at("(")) {                 // method call obj.m(args)
          self.adv();
          let args: Vec<Box<Expr>> = Vec.new();
          if (!self.at(")")) {
            args.push(self.parseExpr());
            while (self.at(",")) { self.adv(); args.push(self.parseExpr()); }
          }
          self.eat(")");
          e = Box.new(MethodCall(e, m, args));
        } else {
          e = Box.new(Field(e, m));               // field access obj.f
        }
      }
    }
    return e;
  }
  function parseUnary(&mut self): Box<Expr> {
    if (self.at("comptime")) { self.adv(); return Box.new(Comptime(self.parseUnary())); }   // build-time eval (emit is a no-op; checker forbids reading runtime values)
    if (self.at("!")) { self.adv(); let e: Box<Expr> = self.parseUnary(); return Box.new(Not(e)); }
    if (self.at("&")) {   // &e / &mut e -> Borrow (erased in emit)
      self.adv();
      let isMut: bool = false;
      if (self.at("mut")) { self.adv(); isMut = true; }
      let e: Box<Expr> = self.parseUnary();
      return Box.new(Borrow(isMut, e));
    }
    return self.parsePostfix();
  }
  function parseCast(&mut self): Box<Expr> {   // e as T (binds tighter than * /)
    let e: Box<Expr> = self.parseUnary();
    while (self.at("as")) {
      self.adv();
      let fallible: bool = false;
      if (self.at("?")) { self.adv(); fallible = true; }          // as? -> fallible cast
      let t: str = self.parseType();
      if (fallible) { e = Box.new(TryCast(e, t)); } else { e = Box.new(Cast(e, t)); }
    }
    return e;
  }
  function parseMul(&mut self): Box<Expr> {
    let left: Box<Expr> = self.parseCast();
    while (self.at("*") || self.at("/") || self.at("%") || self.at("*%") || self.at("*|")) {
      let op: str = self.word();
      let right: Box<Expr> = self.parseCast();
      left = Box.new(Bin(op, left, right));
    }
    return left;
  }
  function parseAdd(&mut self): Box<Expr> {
    let left: Box<Expr> = self.parseMul();
    while (self.at("+") || self.at("-") || self.at("+%") || self.at("-%") || self.at("+|") || self.at("-|")) {
      let op: str = self.word();
      let right: Box<Expr> = self.parseMul();
      left = Box.new(Bin(op, left, right));
    }
    return left;
  }
  function parseCmp(&mut self): Box<Expr> {
    let left: Box<Expr> = self.parseAdd();
    while (self.at("<") || self.at("<=") || self.at(">") || self.at(">=") || self.at("==") || self.at("!=")) {
      let op: str = self.word();
      let right: Box<Expr> = self.parseAdd();
      left = Box.new(Bin(op, left, right));
    }
    return left;
  }
  function parseAnd(&mut self): Box<Expr> {
    let left: Box<Expr> = self.parseCmp();
    while (self.at("&&")) { self.adv(); let right: Box<Expr> = self.parseCmp(); left = Box.new(Bin("&&", left, right)); }
    return left;
  }
  function parseLogOr(&mut self): Box<Expr> {
    let left: Box<Expr> = self.parseAnd();
    while (self.at("||")) { self.adv(); let right: Box<Expr> = self.parseAnd(); left = Box.new(Bin("||", left, right)); }
    return left;
  }
  function parseExpr(&mut self): Box<Expr> {   // `a ?? b` is the loosest binary
    let left: Box<Expr> = self.parseLogOr();
    while (self.at("??")) { self.adv(); let right: Box<Expr> = self.parseLogOr(); left = Box.new(OrElse(left, right)); }
    return left;
  }

  function parseBlock(&mut self): Vec<Stmt> {
    self.eat("{");
    let out: Vec<Stmt> = Vec.new();
    while (!self.at("}")) { out.push(self.parseStmt()); }
    self.eat("}");
    return out;
  }
  function parseStmt(&mut self): Stmt {
    if (self.at("let") || self.at("const")) {   // local const is an immutable let; type annotation optional (-> auto)
      let isConst: bool = self.at("const");
      self.adv();
      let name: str = self.word();
      let ty: str = "auto";
      if (self.at(":")) { self.adv(); ty = self.parseType(); }
      self.eat("=");
      let v: Box<Expr> = self.parseExpr();
      self.eat(";");
      return Let(name, ty, v, isConst);
    }
    if (self.at("return")) {
      self.adv();
      if (self.at(";")) { self.adv(); return RetVoid; }
      let v: Box<Expr> = self.parseExpr();
      self.eat(";");
      return Ret(v);
    }
    if (self.at("defer")) {
      self.adv();
      if (self.at("{")) { return Defer(self.parseBlock()); }
      let body: Vec<Stmt> = Vec.new();
      body.push(self.parseStmt());
      return Defer(body);
    }
    if (self.at("if")) {
      self.adv(); self.eat("(");
      let c: Box<Expr> = self.parseExpr();
      self.eat(")");
      let then: Vec<Stmt> = self.parseBlock();
      let els: Vec<Stmt> = Vec.new();
      if (self.at("else")) {
        self.adv();
        if (self.at("if")) { els.push(self.parseStmt()); }   // else if -> nested If
        else { els = self.parseBlock(); }
      }
      return If(c, then, els);
    }
    if (self.at("while")) {
      self.adv(); self.eat("(");
      let c: Box<Expr> = self.parseExpr();
      self.eat(")");
      let body: Vec<Stmt> = self.parseBlock();
      return While(c, body);
    }
    if (self.at("match")) {
      self.adv();
      self.noStruct = true;
      let scrut: Box<Expr> = self.parseExpr();
      self.noStruct = false;
      self.eat("{");
      let arms: Vec<Arm> = Vec.new();
      while (!self.at("}")) {
        let vn: str = self.word();
        let binds: Vec<str> = Vec.new();
        if (self.at("(")) {
          self.adv();
          binds.push(self.word());
          while (self.at(",")) { self.adv(); binds.push(self.word()); }
          self.eat(")");
        }
        self.eat("=>");
        let body: Vec<Stmt> = self.parseBlock();
        arms.push(Arm { variant: vn, bindings: binds, body: body });
      }
      self.eat("}");
      return Match(scrut, arms);
    }
    if (self.at("scope")) {             // scope { spawn ...; } structured concurrency
      self.adv();
      let body: Vec<Stmt> = self.parseBlock();
      return Scope(body);
    }
    if (self.at("shared")) {            // shared name: T; (workgroup/threadgroup memory)
      self.adv();
      let nm: str = self.word();
      self.eat(":");
      let ty: str = self.parseType();
      self.eat(";");
      return Shared(nm, ty);
    }
    if (self.at("for")) {               // for (const x of iter) { ... }
      self.adv(); self.eat("(");
      if (self.at("const") || self.at("let")) { self.adv(); }
      let nm: str = self.word();
      self.eat("of");
      let it: Box<Expr> = self.parseExpr();
      self.eat(")");
      let body: Vec<Stmt> = self.parseBlock();
      return ForOf(nm, it, body);
    }
    if (self.at("stdout")) {            // stdout.println(e);
      self.adv(); self.eat("."); self.eat("println"); self.eat("(");
      let e: Box<Expr> = self.parseExpr();
      self.eat(")"); self.eat(";");
      return Print(e);
    }
    // assignment `lvalue = e;` (lvalue = name / e.field / a[i]) or bare expression `e;`
    let e: Box<Expr> = self.parseExpr();
    if (self.at("=")) {
      self.adv();
      let v: Box<Expr> = self.parseExpr();
      self.eat(";");
      return Assign(e, v);
    }
    self.eat(";");
    return ExprS(e);
  }

  function parseFunc(&mut self): Func {
    self.eat("function");
    let name: str = self.word();
    let tparams: Vec<str> = Vec.new();
    if (self.at("<")) {                 // generic: function name<T, U>(...)
      self.adv();
      tparams.push(self.word());
      while (self.at(",")) { self.adv(); tparams.push(self.word()); }
      self.eat(">");
    }
    self.eat("(");
    let params: Vec<Param> = Vec.new();
    if (!self.at(")")) {
      let pn: str = self.word(); self.eat(":"); let pt: str = self.parseType();
      params.push(Param { name: pn, ty: pt });
      while (self.at(",")) {
        self.adv();
        let qn: str = self.word(); self.eat(":"); let qt: str = self.parseType();
        params.push(Param { name: qn, ty: qt });
      }
    }
    self.eat(")");
    let ret: str = "";
    if (self.at(":")) { self.adv(); ret = self.parseType(); }
    let body: Vec<Stmt> = self.parseBlock();
    return Func { name: name, tparams: tparams, params: params, ret: ret, body: body, isKernel: false };
  }
  function parseKernel(&mut self): Func {   // kernel name(params) { body } -> CPU void fn with grid_{x,y,z} prepended
    self.eat("kernel");
    let name: str = self.word();
    self.eat("(");
    let params: Vec<Param> = Vec.new();
    if (!self.at(")")) {
      let pn: str = self.word(); self.eat(":"); let pt: str = self.parseType();
      params.push(Param { name: pn, ty: pt });
      while (self.at(",")) {
        self.adv();
        let qn: str = self.word(); self.eat(":"); let qt: str = self.parseType();
        params.push(Param { name: qn, ty: qt });
      }
    }
    self.eat(")");
    let tparams: Vec<str> = Vec.new();
    let body: Vec<Stmt> = self.parseBlock();
    return Func { name: name, tparams: tparams, params: params, ret: "", body: body, isKernel: true };
  }
  function parseMethod(&mut self): Method {
    self.eat("function");
    let name: str = self.word();
    self.eat("(");
    self.eat("&");
    let isMut: bool = false;
    if (self.at("mut")) { self.adv(); isMut = true; }
    self.eat("self");
    let params: Vec<Param> = Vec.new();
    while (self.at(",")) {
      self.adv();
      let pn: str = self.word(); self.eat(":"); let pt: str = self.parseType();
      params.push(Param { name: pn, ty: pt });
    }
    self.eat(")");
    let ret: str = "";
    if (self.at(":")) { self.adv(); ret = self.parseType(); }
    let body: Vec<Stmt> = self.parseBlock();
    return Method { name: name, isMut: isMut, params: params, ret: ret, body: body };
  }
  function parseStruct(&mut self): StructDef {
    self.eat("struct");
    let name: str = self.word();
    let tparams: Vec<str> = Vec.new();
    if (self.at("<")) {                  // struct Name<A, B> -> class template
      self.adv();
      tparams.push(self.word());
      while (self.at(",")) { self.adv(); tparams.push(self.word()); }
      self.eat(">");
    }
    self.eat("{");
    let fields: Vec<Param> = Vec.new();
    let methods: Vec<Method> = Vec.new();
    while (!self.at("}")) {
      if (self.at("function")) { methods.push(self.parseMethod()); }
      else {
        let fname: str = self.word(); self.eat(":"); let fty: str = self.parseType(); self.eat(";");
        fields.push(Param { name: fname, ty: fty });
      }
    }
    self.eat("}");
    return StructDef { name: name, tparams: tparams, fields: fields, methods: methods };
  }
  function parseEnum(&mut self): EnumDef {
    self.eat("enum");
    let name: str = self.word();
    self.eat("{");
    let variants: Vec<Variant> = Vec.new();
    while (!self.at("}")) {
      let vn: str = self.word();
      let payloads: Vec<str> = Vec.new();
      if (self.at("(")) {
        self.adv();
        payloads.push(self.parseType());
        while (self.at(",")) { self.adv(); payloads.push(self.parseType()); }
        self.eat(")");
      }
      variants.push(Variant { name: vn, payloads: payloads });
      if (self.at(",")) { self.adv(); }
    }
    self.eat("}");
    return EnumDef { name: name, variants: variants };
  }
  function parseConst(&mut self): ConstD {
    self.eat("const");
    let name: str = self.word();
    self.eat(":");
    let ty: str = self.parseType();
    self.eat("=");
    let v: Box<Expr> = self.parseExpr();
    self.eat(";");
    return ConstD { name: name, ty: ty, value: v };
  }
  // Split a template's raw content into literal `strings` and reparsed `${...}` `exprs`.
  // Escapes are kept raw (so emit can wrap each literal in C++ "..." directly).
  function parseTemplate(&mut self, raw: str): Box<Expr> {
    let strings: Vec<str> = Vec.new();
    let exprs: Vec<Box<Expr>> = Vec.new();
    let cur: str = "";
    let i: u32 = 0;
    let n: u32 = raw.len;
    while (i < n) {
      if (raw[i] == '\\') {
        cur = cur + format(raw[i]); i = i +% 1;
        if (i < n) { cur = cur + format(raw[i]); i = i +% 1; }
      } else if (raw[i] == '$' && i +% 1 < n && raw[i +% 1] == '{') {
        strings.push(cur); cur = "";
        let brace: i32 = 1;
        let j: u32 = i +% 2;
        let src2: str = "";
        while (j < n && brace > 0) {
          let d: char = raw[j];
          if (d == '{') { brace = brace +% 1; src2 = src2 + format(d); }
          else if (d == '}') { brace = brace -% 1; if (brace > 0) { src2 = src2 + format(d); } }
          else { src2 = src2 + format(d); }
          j = j +% 1;
        }
        let sub: Parser = Parser { toks: lex(src2), pos: 0, structs: Vec.new(), enums: Vec.new(), consts: Vec.new(), noStruct: false };
        exprs.push(sub.parseExpr());
        i = j;
      } else {
        cur = cur + format(raw[i]); i = i +% 1;
      }
    }
    strings.push(cur);
    return Box.new(Template(strings, exprs));
  }
  function parseProgram(&mut self): Vec<Func> {
    let funcs: Vec<Func> = Vec.new();
    while (self.kind() != KEOF) {
      if (self.at("struct")) { let sd: StructDef = self.parseStruct(); self.structs.push(sd); }
      else if (self.at("enum")) { let ed: EnumDef = self.parseEnum(); self.enums.push(ed); }
      else if (self.at("const")) { let cd: ConstD = self.parseConst(); self.consts.push(cd); }
      else if (self.at("kernel")) { funcs.push(self.parseKernel()); }
      else { funcs.push(self.parseFunc()); }
    }
    return funcs;
  }
}

// ---- emitter (AST -> C++) ----
function substr(s: str, a: u32, b: u32): str {   // s[a..b)
  let r: str = "";
  let i: u32 = a;
  while (i < b) { r = r + format(s[i]); i = i +% 1; }
  return r;
}
function allDigits(s: str): bool {
  if (s.len == 0) { return false; }
  let i: u32 = 0;
  while (i < s.len) { if (s[i] < '0' || s[i] > '9') { return false; } i = i +% 1; }
  return true;
}
function laneType(s: str): str {   // C++ lane type for a SIMD scalar prefix; "" if not a numeric scalar
  if (s == "i8" || s == "i16" || s == "i32" || s == "i64" || s == "u8" || s == "u16" || s == "u32" || s == "u64" || s == "f16" || s == "f32" || s == "f64") { return mapType(s); }
  return "";
}
// SIMD type name like "f32x4" -> "mz::Simd<float, 4>" ("" if not a SIMD name). simdLane gives just "float".
function simdSplitLane(w: str): str {
  let xpos: u32 = 0; let found: bool = false; let i: u32 = 0;
  while (i < w.len) { if (!found && w[i] == 'x') { xpos = i; found = true; } i = i +% 1; }
  if (!found) { return ""; }
  return laneType(substr(w, 0, xpos));
}
function simdCpp(w: str): str {
  let xpos: u32 = 0; let found: bool = false; let i: u32 = 0;
  while (i < w.len) { if (!found && w[i] == 'x') { xpos = i; found = true; } i = i +% 1; }
  if (!found) { return ""; }
  let lt: str = laneType(substr(w, 0, xpos));
  if (lt == "") { return ""; }
  let cnt: str = substr(w, xpos +% 1, w.len);
  if (!allDigits(cnt)) { return ""; }
  return `mz::Simd<${lt}, ${cnt}>`;
}
function indexOf(s: str, ch: char, from: u32): u32 {   // first index of ch at/after `from`, else s.len
  let i: u32 = from;
  while (i < s.len) { if (s[i] == ch) { return i; } i = i +% 1; }
  return s.len;
}
function trimLeft(s: str): str {
  let i: u32 = 0;
  while (i < s.len && (s[i] == ' ' || s[i] == '\t')) { i = i +% 1; }
  return substr(s, i, s.len);
}
function contains(v: &Vec<str>, s: str): bool {
  let i: u32 = 0;
  while (i < v.len) { if (v[i] == s) { return true; } i = i +% 1; }
  return false;
}
function importPath(line: str): str {   // `import "X";` -> X, else ""
  let t: str = trimLeft(line);
  if (!startsWith(t, "import")) { return ""; }
  let q1: u32 = indexOf(t, '"', 0);
  if (q1 >= t.len) { return ""; }
  let q2: u32 = indexOf(t, '"', q1 +% 1);
  if (q2 >= t.len) { return ""; }
  return substr(t, q1 +% 1, q2);
}
function dirOf(path: str): str {   // directory prefix (through the last '/'), or "" if none
  let last: i32 = 0 - 1;
  let i: u32 = 0;
  while (i < path.len) { if (path[i] == '/') { last = i as i32; } i = i +% 1; }
  if (last < 0) { return ""; }
  return substr(path, 0, (last as u32) +% 1);
}
// Resolve `import "p";` lines: read each referenced file once (dedup via `seen`), recursively expand
// its imports (relative to ITS directory), and concatenate dependencies-first, dropping the import lines.
function resolveImports(src: str, baseDir: str, seen: &mut Vec<str>): str {
  let deps: str = "";
  let body: str = "";
  let line: str = "";
  let i: u32 = 0;
  while (i <= src.len) {
    if (i == src.len || src[i] == '\n') {
      let imp: str = importPath(line);
      if (imp != "") {
        let full: str = baseDir + imp;
        if (!contains(seen, full)) {
          seen.push(full);
          let isrc: str = readFile(baseDir + imp) ?? "";
          deps = deps + resolveImports(isrc, dirOf(baseDir + imp), seen);
        }
      } else {
        body = body + line + "\n";
      }
      line = "";
    } else {
      line = line + format(src[i]);
    }
    i = i +% 1;
  }
  return deps + body;
}
function startsWith(s: str, pre: str): bool {
  if (pre.len > s.len) { return false; }
  let i: u32 = 0;
  while (i < pre.len) { if (s[i] != pre[i]) { return false; } i = i +% 1; }
  return true;
}
// A C++ type that is Sync/non-copyable, hence passed by reference (shared, never copied).
function isSyncType(ty: str): bool {
  return startsWith(ty, "mz::Buffer") || startsWith(ty, "std::atomic") || startsWith(ty, "mz::Mutex") || startsWith(ty, "mz::Channel");
}
// A user struct is Sync if any field is a Sync type (e.g. struct Counter { hits: Atomic<u64> }).
function structIsSync(structs: &Vec<StructDef>, name: str): bool {
  let i: u32 = 0;
  while (i < structs.len) {
    if (structs[i].name == name) {
      let fi: u32 = 0;
      while (fi < structs[i].fields.len) { if (isSyncType(structs[i].fields[fi].ty)) { return true; } fi = fi +% 1; }
      return false;
    }
    i = i +% 1;
  }
  return false;
}
function isMutRefTy(ty: str): bool {   // explicit &mut T lowers to "T&" (ends with &, not const&)
  if (ty.len == 0) { return false; }
  if (ty[ty.len -% 1] != '&') { return false; }
  return !startsWith(ty, "const ");
}
// __restrict tells C++ "no other pointer reaches this object here" — sound where the borrow checker
// guarantees it. A &mut (non-by-ref) param is exclusive; kernel Buffer params are pairwise-distinct
// (launch rejects passing one buffer twice). & (shared) and &mut Buffer/Atomic/... are NOT restricted.
function paramDecl(ty: str, name: str, structs: &Vec<StructDef>, restrictBuf: bool): str {
  if (isMutRefTy(ty)) {
    let inner: str = substr(ty, 0, ty.len -% 1);   // drop trailing &
    if (isSyncType(inner)) { return ty + " " + name; }   // &mut Buffer/Atomic/... may alias a bare arg
    return ty + " __restrict " + name;                   // &mut non-by-ref: exclusive
  }
  if (isSyncType(ty) || structIsSync(structs, ty)) {     // by-ref: shared across threads, never copied
    if (restrictBuf && startsWith(ty, "mz::Buffer")) { return ty + "& __restrict " + name; }   // kernel buffers: non-aliasing
    return ty + "& " + name;
  }
  return ty + " " + name;
}
function mapType(t: str): str {
  if (t == "i8") { return "int8_t"; }
  if (t == "i16") { return "int16_t"; }
  if (t == "i32") { return "int32_t"; }
  if (t == "i64") { return "int64_t"; }
  if (t == "i128") { return "__int128"; }
  if (t == "u128") { return "unsigned __int128"; }
  if (t == "u8") { return "uint8_t"; }
  if (t == "u16") { return "uint16_t"; }
  if (t == "u32") { return "uint32_t"; }
  if (t == "u64") { return "uint64_t"; }
  if (t == "bool") { return "bool"; }
  if (t == "str") { return "std::u32string"; }   // codepoint string (.len = code points, s[i] = code point)
  if (t == "char") { return "char32_t"; }
  if (t == "f16") { return "_Float16"; }
  if (t == "f32") { return "float"; }
  if (t == "f64") { return "double"; }
  if (t == "Task") { return "std::thread"; }   // void task
  if (t == "Device") { return "mz::Device"; }
  if (t == "Job") { return "mz::Job"; }
  return t;   // user struct/enum type names pass through unchanged
}
function methodParams(m: &Method, structs: &Vec<StructDef>): str {
  let s: str = "";
  let i: u32 = 0;
  while (i < m.params.len) { if (i > 0) { s = s + ", "; } s = s + paramDecl(m.params[i].ty, m.params[i].name, structs, false); i = i +% 1; }
  return s;
}
function methodRet(m: &Method): str { if (m.ret.len > 0) { return m.ret; } return "void"; }
function emitStruct(s: &StructDef, enums: &Vec<EnumDef>, structs: &Vec<StructDef>): str {
  let out: str = `${tprefix(&s.tparams)}struct ${s.name} {`;
  let i: u32 = 0;
  while (i < s.fields.len) { out = out + ` ${mapType(s.fields[i].ty)} ${s.fields[i].name};`; i = i +% 1; }
  let gen: bool = s.tparams.len > 0;
  let mi: u32 = 0;
  while (mi < s.methods.len) {
    let cst: str = "";
    if (!s.methods[mi].isMut) { cst = " const"; }
    if (gen) {                                       // template: method bodies must be inline
      out = out + ` ${methodRet(&s.methods[mi])} ${s.methods[mi].name}(${methodParams(&s.methods[mi], structs)})${cst} {\n${emitBlock(&s.methods[mi].body, "  ", enums)}}`;
    } else {                                         // non-generic: declare here, define out-of-line
      out = out + ` ${methodRet(&s.methods[mi])} ${s.methods[mi].name}(${methodParams(&s.methods[mi], structs)})${cst};`;
    }
    mi = mi +% 1;
  }
  return out + " };\n";
}
// Out-of-line method bodies (after fn prototypes, so a method may call free functions). self -> (*this).
// Generic structs emit their method bodies inline (in emitStruct), so they are skipped here.
function emitMethodDefs(s: &StructDef, enums: &Vec<EnumDef>, structs: &Vec<StructDef>): str {
  if (s.tparams.len > 0) { return ""; }
  let out: str = "";
  let mi: u32 = 0;
  while (mi < s.methods.len) {
    let cst: str = "";
    if (!s.methods[mi].isMut) { cst = " const"; }
    out = out + `${methodRet(&s.methods[mi])} ${s.name}::${s.methods[mi].name}(${methodParams(&s.methods[mi], structs)})${cst} {\n${emitBlock(&s.methods[mi].body, "  ", enums)}}\n`;
    mi = mi +% 1;
  }
  return out;
}
// Look up an enum variant by name (so a Call/Var to a variant emits a tagged-union construction).
function findVariant(enums: &Vec<EnumDef>, name: str): VInfo {
  let ei: u32 = 0;
  while (ei < enums.len) {
    let vi: u32 = 0;
    while (vi < enums[ei].variants.len) {
      if (enums[ei].variants[vi].name == name) {
        return VInfo { found: true, enumName: enums[ei].name, tag: (vi as i32), payloads: enums[ei].variants[vi].payloads };
      }
      vi = vi +% 1;
    }
    ei = ei +% 1;
  }
  return VInfo { found: false, enumName: "", tag: 0, payloads: Vec.new() };
}
// enum -> a tagged-union struct: { int tag; <payload fields Variant_i>; }  (matches the real compiler).
function emitEnum(ed: &EnumDef): str {
  let out: str = `struct ${ed.name} { int tag;`;
  let vi: u32 = 0;
  while (vi < ed.variants.len) {
    let pi: u32 = 0;
    while (pi < ed.variants[vi].payloads.len) {
      out = out + ` ${mapType(ed.variants[vi].payloads[pi])} ${ed.variants[vi].name}_${format(pi)};`;
      pi = pi +% 1;
    }
    vi = vi +% 1;
  }
  return out + " };\n";
}
// Escape a (raw) string for a C++ "..." literal: bare " becomes \" ; existing \X pairs pass through.
function cesc(s: str): str {
  let out: str = "";
  let i: u32 = 0;
  let n: u32 = s.len;
  while (i < n) {
    if (s[i] == '\\') { out = out + format(s[i]); i = i +% 1; if (i < n) { out = out + format(s[i]); i = i +% 1; } }
    else if (s[i] == '"') { out = out + format('\\') + format('"'); i = i +% 1; }
    else { out = out + format(s[i]); i = i +% 1; }
  }
  return out;
}
function spawnArgs(args: &Vec<Box<Expr>>, enums: &Vec<EnumDef>): str {   // &x -> std::ref(x) so the thread shares it
  let s: str = "";
  let i: u32 = 0;
  while (i < args.len) {
    if (i > 0) { s = s + ", "; }
    match args[i].get() {
      Borrow(bm, inner) => { s = s + `std::ref(${emitExpr(inner.get(), enums)})`; }
      _ => { s = s + emitExpr(args[i].get(), enums); }
    }
    i = i +% 1;
  }
  return s;
}
function varName(e: &Expr): str {   // the identifier of a Var expr, else ""
  match e {
    Var(n) => { return n; }
    _ => { }
  }
  return "";
}
// The grid argument of a launch: grid2(w,h)/grid3(x,y,z) build an mz::Grid; a bare scalar is 1-D.
function gridArg(e: &Expr, enums: &Vec<EnumDef>): str {
  match e {
    Call(nm, a) => {
      if (nm == "grid2") { return `mz::Grid{ (uint32_t)(${emitExpr(a[0].get(), enums)}), (uint32_t)(${emitExpr(a[1].get(), enums)}), 1 }`; }
      if (nm == "grid3") { return `mz::Grid{ (uint32_t)(${emitExpr(a[0].get(), enums)}), (uint32_t)(${emitExpr(a[1].get(), enums)}), (uint32_t)(${emitExpr(a[2].get(), enums)}) }`; }
    }
    _ => { }
  }
  return `mz::Grid{ (uint32_t)(${emitExpr(e, enums)}), 1, 1 }`;
}
// args[from..] of a launch call, each comma-prefixed (kernel call args; & is erased by emitExpr).
function launchArgs(args: &Vec<Box<Expr>>, from: u32, enums: &Vec<EnumDef>): str {
  let s: str = "";
  let i: u32 = from;
  while (i < args.len) { s = s + ", " + emitExpr(args[i].get(), enums); i = i +% 1; }
  return s;
}
function emitExpr(e: &Expr, enums: &Vec<EnumDef>): str {
  match e {
    Num(v) => { return format(v); }
    FloatLit(s) => { return s; }
    Var(name) => {
      if (name == "self") { return "(*this)"; }
      if (name == "Relaxed") { return "std::memory_order_relaxed"; }
      if (name == "Acquire") { return "std::memory_order_acquire"; }
      if (name == "Release") { return "std::memory_order_release"; }
      if (name == "AcqRel") { return "std::memory_order_acq_rel"; }
      if (name == "SeqCst") { return "std::memory_order_seq_cst"; }
      let vi: VInfo = findVariant(enums, name);
      if (vi.found) { return `${vi.enumName}{ .tag = ${format(vi.tag)} }`; }   // unit variant
      return name;
    }
    StrLit(s) => { return `std::u32string(U"${cesc(s)}")`; }   // u32string object (so + / == work; non-ASCII passes through as UTF-8 source)
    CharLit(cp) => { return `(char32_t)${format(cp)}`; }
    Cast(x, t) => { return `(${t})(${emitExpr(x.get(), enums)})`; }
    Some(x) => { return `{ ${emitExpr(x.get(), enums)} }`; }
    NoneLit => { return "std::nullopt"; }
    TryQ(x) => { return `({ auto _t = (${emitExpr(x.get(), enums)}); if (!mz::is_ok(_t)) return _t; mz::get_val(_t); })`; }
    TryCast(x, t) => { return `mz::checked_cast<${t}>(${emitExpr(x.get(), enums)})`; }
    OkE(x) => { return `{ true, ${emitExpr(x.get(), enums)} }`; }
    ErrE(x) => { return `{ false, {}, ${emitExpr(x.get(), enums)} }`; }
    OrElse(a, b) => { return `(${emitExpr(a.get(), enums)}).value_or(${emitExpr(b.get(), enums)})`; }
    SpawnExpr(fn, sa) => { return fn; }   // only meaningful as a let value (handled in Let); standalone unused
    Comptime(x) => { return emitExpr(x.get(), enums); }   // build-time value -> emit the operand (C++ folds / static-inits it)
    BoolLit(b) => { if (b) { return "true"; } return "false"; }
    Not(x) => { return `(!${emitExpr(x.get(), enums)})`; }
    Field(o, f) => {
      let ov: str = varName(o.get());
      if ((ov == "grid" || ov == "local" || ov == "group") && (f == "x" || f == "y" || f == "z")) { return `${ov}_${f}`; }   // GPU thread indices -> kernel params
      if (ov == "Device" && f == "gpu") { return "mz::Device{ 1 }"; }
      if (ov == "Device" && f == "cpu") { return "mz::Device{ 0 }"; }
      if (f == "len") { return `(${emitExpr(o.get(), enums)}).size()`; }   // .len -> .size() (array/string)
      return `(${emitExpr(o.get(), enums)}).${f}`;
    }
    Index(o, idx) => { return `(${emitExpr(o.get(), enums)})[${emitExpr(idx.get(), enums)}]`; }
    Borrow(bm, x) => { return emitExpr(x.get(), enums); }   // erase & — the C++ reference param binds to the lvalue
    ArrLit(elems) => {                          // std::array aggregate needs double braces (recursive for nesting)
      let s: str = "{{ ";
      let ai: u32 = 0;
      while (ai < elems.len) { if (ai > 0) { s = s + ", "; } s = s + emitExpr(elems[ai].get(), enums); ai = ai +% 1; }
      return s + " }}";
    }
    Bin(op, l, r) => {                          // wrapping/saturating ops lower to native operators
      let a: str = emitExpr(l.get(), enums);
      let b: str = emitExpr(r.get(), enums);
      if (op == "+%") { return `mz::wrap_add(${a}, ${b})`; }   // wrapping (two's complement), left-typed
      if (op == "-%") { return `mz::wrap_sub(${a}, ${b})`; }
      if (op == "*%") { return `mz::wrap_mul(${a}, ${b})`; }
      if (op == "+|") { return `mz::sat_add(${a}, ${b})`; }    // saturating (clamp to type min/max)
      if (op == "-|") { return `mz::sat_sub(${a}, ${b})`; }
      if (op == "*|") { return `mz::sat_mul(${a}, ${b})`; }
      return `(${a} ${op} ${b})`;
    }
    Call(name, args) => {
      let simd: str = simdCpp(name);                 // f32x4(a,b,c,d) lane-constructor
      if (simd != "") {
        let lt: str = simdSplitLane(name);
        let s: str = simd + "{ {";
        let k: u32 = 0;
        while (k < args.len) { if (k > 0) { s = s + ", "; } s = s + `(${lt})(${emitExpr(args[k].get(), enums)})`; k = k +% 1; }   // cast each lane (no narrowing in braced-init)
        return s + "} }";
      }
      if (name == "barrier") { return "_bar.arrive_and_wait()"; }   // workgroup barrier
      if (name == "launch") {                        // launch(kernel, gridSize, kargs...) -> serial mz::launch
        let kn: str = varName(args[0].get());
        match args[1].get() {                        // gridGroups(ngrp, gs) -> workgroup launch via the _wg wrapper
          Call(gn, ga) => {
            if (gn == "gridGroups") {
              return `_wg_${kn}(mz::Grid{ (uint32_t)(${emitExpr(ga[0].get(), enums)}) * (uint32_t)(${emitExpr(ga[1].get(), enums)}), 1, 1, (uint32_t)(${emitExpr(ga[1].get(), enums)}), 1, 1 }${launchArgs(&args, 2, enums)})`;
            }
          }
          _ => { }
        }
        return `mz::launch(${gridArg(args[1].get(), enums)}, [&](uint32_t grid_x, uint32_t grid_y, uint32_t grid_z){ ${kn}(grid_x, grid_y, grid_z${launchArgs(&args, 2, enums)}); })`;
      }
      if (name == "format") { return `mz::ufmt(${emitExpr(args[0].get(), enums)})`; }   // -> u32string (str)
      if (name == "slice") { return `mz::make_slice(${emitExpr(args[0].get(), enums)})`; }
      if (name == "readFile") { return `mz::read_file(${emitExpr(args[0].get(), enums)})`; }
      if (name == "writeFile") { return `mz::write_file(${emitExpr(args[0].get(), enums)}, ${emitExpr(args[1].get(), enums)})`; }
      if (name == "abort") {
        if (args.len > 0) { return `mz::panic_msg(${emitExpr(args[0].get(), enums)})`; }
        return "mz::panic_msg(U\"aborted\")";
      }
      if (name == "assert") { return `mz::assert_(${emitExpr(args[0].get(), enums)})`; }   // message dropped (subset)
      let vi: VInfo = findVariant(enums, name);
      if (vi.found) {                              // enum-variant construction
        let s: str = `${vi.enumName}{ .tag = ${format(vi.tag)}`;
        let k: u32 = 0;
        while (k < args.len) { s = s + `, .${name}_${format(k)} = ${emitExpr(args[k].get(), enums)}`; k = k +% 1; }
        return s + " }";
      }
      let s2: str = name + "(";                    // function call
      let i: u32 = 0;
      while (i < args.len) { if (i > 0) { s2 = s2 + ", "; } s2 = s2 + emitExpr(args[i].get(), enums); i = i +% 1; }
      return s2 + ")";
    }
    StructLit(name, vals) => {
      let s: str = name + "{ ";
      let j: u32 = 0;
      while (j < vals.len) { if (j > 0) { s = s + ", "; } s = s + emitExpr(vals[j].get(), enums); j = j +% 1; }
      return s + " }";
    }
    Template(strs, exprs) => {
      let s: str = `std::u32string(U"${cesc(strs[0])}")`;
      let k: u32 = 0;
      while (k < exprs.len) {
        s = s + ` + mz::ufmt(${emitExpr(exprs[k].get(), enums)}) + U"${cesc(strs[k +% 1])}"`;
        k = k +% 1;
      }
      return `(${s})`;
    }
    MethodCall(o, m, args) => {
      let recv: str = varName(o.get());
      if (m == "launch" && args.len >= 2) {          // dev.launch(kernel, grid, kargs...) -> serial launch, returns a Job
        let kn: str = varName(args[0].get());
        return `([&]{ mz::launch(${gridArg(args[1].get(), enums)}, [&](uint32_t grid_x, uint32_t grid_y, uint32_t grid_z){ ${kn}(grid_x, grid_y, grid_z${launchArgs(&args, 2, enums)}); }); return mz::Job{}; }())`;
      }
      if (m == "splat" && simdCpp(recv) != "") { return `${simdCpp(recv)}::splat(${emitExpr(args[0].get(), enums)})`; }   // f32x4.splat(s)
      if (recv == "Box" && m == "new") { return `mz::box_new(${emitExpr(args[0].get(), enums)})`; }
      if (recv == "Arc" && m == "new") { return `mz::arc_new(${emitExpr(args[0].get(), enums)})`; }
      if (recv == "Atomic" && m == "new") { return emitExpr(args[0].get(), enums); }   // in a struct literal: Atomic.new(0) -> 0 (direct-init the atomic field)
      if (recv == "stdin" && m == "readAll") { return "mz::read_all_stdin()"; }
      if (recv == "stdin" && m == "lines") { return "mz::stdin_lines()"; }
      if (recv == "clock" && m == "now") { return "mz::now_ns()"; }
      if (m == "new" && (recv == "Vec" || recv == "Map" || recv == "Channel")) { return "{}"; }   // default-construct (type from context)
      if (recv == "String" && m == "new") { return "std::u32string()"; }
      if (m == "push") { return `(${emitExpr(o.get(), enums)}).push_back(${emitExpr(args[0].get(), enums)})`; }   // Vec.push / String.push -> push_back
      if (m == "pushStr") { return `(${emitExpr(o.get(), enums)}).append(${emitExpr(args[0].get(), enums)})`; }   // String.pushStr -> append
      if (m == "fetchAdd") { return `(${emitExpr(o.get(), enums)}).fetch_add(${emitExpr(args[0].get(), enums)}, ${emitExpr(args[1].get(), enums)})`; }
      if (m == "compareExchange") {
        let ob: str = emitExpr(o.get(), enums);
        return `([&]{ auto _e = (decltype((${ob}).load(std::memory_order_relaxed)))(${emitExpr(args[0].get(), enums)}); return (${ob}).compare_exchange_strong(_e, ${emitExpr(args[1].get(), enums)}, ${emitExpr(args[2].get(), enums)}, ${emitExpr(args[3].get(), enums)}); }())`;
      }
      if (m == "unwrap") { return `mz::result_unwrap(${emitExpr(o.get(), enums)})`; }              // Result accessors
      if (m == "unwrapErr") { return `mz::result_unwrap_err(${emitExpr(o.get(), enums)})`; }
      if (m == "isOk") { return `(${emitExpr(o.get(), enums)}).ok`; }
      if (m == "isErr") { return `(!(${emitExpr(o.get(), enums)}).ok)`; }
      let s: str = `(${emitExpr(o.get(), enums)}).${m}(`;
      let k: u32 = 0;
      while (k < args.len) { if (k > 0) { s = s + ", "; } s = s + emitExpr(args[k].get(), enums); k = k +% 1; }
      return s + ")";
    }
  }
  return "0";
}
function emitBlock(body: &Vec<Stmt>, ind: str, enums: &Vec<EnumDef>): str {
  let s: str = "";
  let i: u32 = 0;
  while (i < body.len) { s = s + emitStmt(&body[i], ind, enums); i = i +% 1; }
  return s;
}
function emitStmt(s: &Stmt, ind: str, enums: &Vec<EnumDef>): str {
  match s {
    Let(name, ty, v, isConst) => {
      match v.get() {
        SpawnExpr(fn, sa) => {
          if (ty == "std::thread") { return `${ind}std::thread ${name}(${fn}, ${spawnArgs(&sa, enums)});\n`; }
          return `${ind}${mapType(ty)} ${name}{ std::async(std::launch::async, ${fn}, ${spawnArgs(&sa, enums)}) };\n`;   // Task<R>
        }
        ArrLit(elems) => {
          if (ty == "auto") {                  // untyped `let xs = [..]` -> std::to_array deduces element type + N
            let inner: str = "";
            let k: u32 = 0;
            while (k < elems.len) { if (k > 0) { inner = inner + ", "; } inner = inner + emitExpr(elems[k].get(), enums); k = k +% 1; }
            return `${ind}auto ${name} = std::to_array({ ${inner} });\n`;
          }
        }
        MethodCall(o, m, margs) => {
          let rv: str = varName(o.get());
          if (rv == "Atomic" && m == "new") { return `${ind}${mapType(ty)} ${name}{ ${emitExpr(margs[0].get(), enums)} };\n`; }   // non-movable: brace-init in place
          if (rv == "Mutex" && m == "new") { return `${ind}${mapType(ty)} ${name}; ${name}.val = ${emitExpr(margs[0].get(), enums)};\n`; }   // std::mutex non-movable: construct in place, then set
          if (rv == "Buffer" && m == "shared") { return `${ind}${mapType(ty)} ${name}(${emitExpr(margs[0].get(), enums)});\n`; }
        }
        _ => { }
      }
      return `${ind}${mapType(ty)} ${name} = ${emitExpr(v.get(), enums)};\n`;
    }
    Assign(target, v) => { return `${ind}${emitExpr(target.get(), enums)} = ${emitExpr(v.get(), enums)};\n`; }
    Ret(v) => { return `${ind}return ${emitExpr(v.get(), enums)};\n`; }
    RetVoid => { return `${ind}return;\n`; }
    Print(v) => { return `${ind}std::cout << mz::fmt(${emitExpr(v.get(), enums)}) << "\\n";\n`; }   // fmt -> bool/char/str/num uniformly
    ExprS(v) => { return `${ind}${emitExpr(v.get(), enums)};\n`; }
    If(c, then, els) => {
      let inner: str = ind + "  ";
      let out: str = `${ind}if (${emitExpr(c.get(), enums)}) {\n${emitBlock(&then, inner, enums)}${ind}}`;
      if (els.len > 0) { out = out + ` else {\n${emitBlock(&els, inner, enums)}${ind}}`; }
      return out + "\n";
    }
    While(c, body) => {
      let inner: str = ind + "  ";
      return `${ind}while (${emitExpr(c.get(), enums)}) {\n${emitBlock(&body, inner, enums)}${ind}}\n`;
    }
    ForOf(nm, it, body) => {
      let inner: str = ind + "  ";
      return `${ind}for (auto& ${nm} : ${emitExpr(it.get(), enums)}) {\n${emitBlock(&body, inner, enums)}${ind}}\n`;
    }
    Shared(nm, ty) => { return ""; }   // declared per-group in the _wg wrapper; passed in as a param
    Defer(body) => { return `${ind}MZ_DEFER(\n${emitBlock(&body, ind + "  ", enums)}${ind});\n`; }
    Scope(body) => {
      let out: str = `${ind}{\n${ind}  std::vector<std::thread> _sc;\n`;
      let i: u32 = 0;
      while (i < body.len) {
        match body[i] {
          ExprS(e) => {
            match e.get() {
              SpawnExpr(fn, sa) => { out = out + `${ind}  _sc.emplace_back(${fn}, ${spawnArgs(&sa, enums)});\n`; }
              _ => { out = out + emitStmt(&body[i], ind + "  ", enums); }
            }
          }
          _ => { out = out + emitStmt(&body[i], ind + "  ", enums); }
        }
        i = i +% 1;
      }
      return out + `${ind}  for (auto& _t : _sc) _t.join();\n${ind}}\n`;
    }
    Match(scrut, arms) => {
      let inner: str = ind + "  ";
      let out: str = `${ind}{ auto _m = ${emitExpr(scrut.get(), enums)};\n${ind}switch (_m.tag) {\n`;
      let ai: u32 = 0;
      while (ai < arms.len) {
        if (arms[ai].variant == "_") {
          out = out + `${ind}default: {\n${emitBlock(&arms[ai].body, inner, enums)}${ind}break; }\n`;
        } else {
          let vi: VInfo = findVariant(enums, arms[ai].variant);
          let binds: str = "";
          let bi: u32 = 0;
          while (bi < arms[ai].bindings.len) {
            binds = binds + `${inner}${mapType(vi.payloads[bi])} ${arms[ai].bindings[bi]} = _m.${arms[ai].variant}_${format(bi)};\n`;
            bi = bi +% 1;
          }
          out = out + `${ind}case ${format(vi.tag)}: {\n${binds}${emitBlock(&arms[ai].body, inner, enums)}${ind}break; }\n`;
        }
        ai = ai +% 1;
      }
      // No `_` arm => the checker proved the match exhaustive, so no other tag occurs: tell the optimizer.
      let hasWild: bool = false;
      let wi: u32 = 0;
      while (wi < arms.len) { if (arms[wi].variant == "_") { hasWild = true; } wi = wi +% 1; }
      if (!hasWild) { out = out + `${ind}default: __builtin_unreachable();\n`; }
      return out + `${ind}} }\n`;
    }
  }
  return "";
}
function retType(f: &Func): str {
  if (f.name == "main") { return "int"; }
  if (f.ret.len > 0) { return mapType(f.ret); }
  return "void";
}
function paramList(f: &Func, structs: &Vec<StructDef>, restrictBuf: bool): str {
  let s: str = "";
  let i: u32 = 0;
  while (i < f.params.len) {
    if (i > 0) { s = s + ", "; }
    s = s + paramDecl(f.params[i].ty, f.params[i].name, structs, restrictBuf);
    i = i +% 1;
  }
  return s;
}
function tprefix(tp: &Vec<str>): str {   // "" or "template <class T, class U>\n"
  if (tp.len == 0) { return ""; }
  let s: str = "template <class " + tp[0];
  let i: u32 = 1;
  while (i < tp.len) { s = s + ", class " + tp[i]; i = i +% 1; }
  return s + ">\n";
}
function collectShared(body: &Vec<Stmt>): Vec<Param> {   // the `shared` decls in a kernel body
  let r: Vec<Param> = Vec.new();
  let i: u32 = 0;
  while (i < body.len) {
    match body[i] {
      Shared(n, t) => { r.push(Param { name: n, ty: t }); }
      _ => { }
    }
    i = i +% 1;
  }
  return r;
}
function kernelSig(f: &Func, structs: &Vec<StructDef>): str {
  let pl: str = paramList(f, structs, true);   // kernel buffers are non-aliasing -> __restrict
  let shared: Vec<Param> = collectShared(&f.body);
  if (shared.len > 0) {   // workgroup kernel: grid + local + group indices, a barrier, and shared arrays
    let sp: str = "";
    let i: u32 = 0;
    while (i < shared.len) { sp = sp + `, ${shared[i].ty}& ${shared[i].name}`; i = i +% 1; }
    let base: str = `void ${f.name}(uint32_t grid_x, uint32_t grid_y, uint32_t grid_z, uint32_t local_x, uint32_t local_y, uint32_t local_z, uint32_t group_x, uint32_t group_y, uint32_t group_z, std::barrier<>& _bar${sp}`;
    if (pl == "") { return base + ")"; }
    return base + ", " + pl + ")";
  }
  if (pl == "") { return `void ${f.name}(uint32_t grid_x, uint32_t grid_y, uint32_t grid_z)`; }
  return `void ${f.name}(uint32_t grid_x, uint32_t grid_y, uint32_t grid_z, ${pl})`;
}
// The host-side fan-out for a workgroup kernel: one std::thread per lane, grouped, sharing a barrier
// and per-group shared arrays. Mirrors the serial Metal threadgroup dispatch on the CPU path.
function emitWgWrapper(f: &Func, structs: &Vec<StructDef>): str {
  let shared: Vec<Param> = collectShared(&f.body);
  let pl: str = paramList(f, structs, false);
  let userParams: str = "";
  if (pl != "") { userParams = ", " + pl; }
  let out: str = `void _wg_${f.name}(mz::Grid _g${userParams}) {\n`;
  out = out + "  uint32_t _total = _g.x;\n  uint32_t _gs = _g.tx ? _g.tx : _total;\n  uint32_t _ngrp = _gs ? (_total + _gs - 1) / _gs : 0;\n";
  out = out + "  for (uint32_t _grp = 0; _grp < _ngrp; _grp++) {\n";
  let si: u32 = 0;
  while (si < shared.len) { out = out + `    ${shared[si].ty} ${shared[si].name}{};\n`; si = si +% 1; }
  out = out + "    std::barrier<> _bar((std::ptrdiff_t)_gs);\n    std::vector<std::thread> _ts;\n";
  out = out + "    for (uint32_t _l = 0; _l < _gs; _l++) {\n      uint32_t _gid = _grp * _gs + _l;\n";
  let sn: str = "";
  let s2: u32 = 0;
  while (s2 < shared.len) { sn = sn + ", " + shared[s2].name; s2 = s2 +% 1; }
  let ua: str = "";
  let ui: u32 = 0;
  while (ui < f.params.len) { ua = ua + ", " + f.params[ui].name; ui = ui +% 1; }
  out = out + `      _ts.emplace_back([&, _gid, _l, _grp]{ ${f.name}(_gid, 0u, 0u, _l, 0u, 0u, _grp, 0u, 0u, _bar${sn}${ua}); });\n`;
  out = out + "    }\n    for (auto& _t : _ts) _t.join();\n  }\n}\n";
  return out;
}
function emitProto(f: &Func, structs: &Vec<StructDef>): str {
  if (f.isKernel) { return kernelSig(f, structs) + ";\n"; }
  return `${retType(f)} ${f.name}(${paramList(f, structs, false)});\n`;
}
function emitFunc(f: &Func, enums: &Vec<EnumDef>, structs: &Vec<StructDef>): str {
  if (f.isKernel) { return kernelSig(f, structs) + ` {\n${emitBlock(&f.body, "  ", enums)}}\n`; }
  // main is `int main()`, but mozaic main is void and may `return;` early — wrap the body in a
  // void IIFE so a bare `return;` exits the lambda, then return 0 from the real main.
  if (f.name == "main") {
    let mbody: str = emitBlock(&f.body, "    ", enums);
    return `int main() {\n  ([&]() -> void {\n${mbody}  })();\n  return 0;\n}\n`;
  }
  let sig: str = `${tprefix(&f.tparams)}${retType(f)} ${f.name}(${paramList(f, structs, false)}) {\n`;
  let body: str = emitBlock(&f.body, "  ", enums);
  return sig + body + "}\n";
}

// ---- a minimal validity checker (mozc has no full type/borrow checker; this rejects the structural
// errors the language forbids: reserved variant names, bad Atomic<T>, atomic in kernels / by-value return,
// array/slice kernel params). Returns an error message, or "" if the program is structurally valid.
function containsSub(s: str, sub: str): bool {
  if (sub.len > s.len) { return false; }
  let i: u32 = 0;
  while (i +% sub.len <= s.len) {
    let j: u32 = 0;
    let ok: bool = true;
    while (j < sub.len) { if (s[i +% j] != sub[j]) { ok = false; j = sub.len; } else { j = j +% 1; } }
    if (ok) { return true; }
    i = i +% 1;
  }
  return false;
}
function validAtomicT(t: str): bool {
  return t == "uint32_t" || t == "int32_t" || t == "uint64_t" || t == "int64_t";
}
function checkTypeStr(ty: str): str {   // Atomic<T> must hold a word-size integer
  if (startsWith(ty, "std::atomic<")) {
    let inner: str = substr(ty, 12, ty.len -% 1);   // strip "std::atomic<" .. ">"
    if (!validAtomicT(inner)) { return "T must be one of u32, i32, u64, i64"; }
  }
  return "";
}
function checkBodyTypes(body: &Vec<Stmt>): str {   // validate let-binding types in nested blocks
  let i: u32 = 0;
  while (i < body.len) {
    match body[i] {
      Let(n, t, v, c) => { let e: str = checkTypeStr(t); if (e != "") { return e; } }
      If(c, then, els) => { let a: str = checkBodyTypes(&then); if (a != "") { return a; } let b: str = checkBodyTypes(&els); if (b != "") { return b; } }
      While(c, wb) => { let e: str = checkBodyTypes(&wb); if (e != "") { return e; } }
      ForOf(n, it, fb) => { let e: str = checkBodyTypes(&fb); if (e != "") { return e; } }
      Scope(sb) => { let e: str = checkBodyTypes(&sb); if (e != "") { return e; } }
      Defer(db) => { let e: str = checkBodyTypes(&db); if (e != "") { return e; } }
      Match(sc, arms) => { let ai: u32 = 0; while (ai < arms.len) { let e: str = checkBodyTypes(&arms[ai].body); if (e != "") { return e; } ai = ai +% 1; } }
      _ => { }
    }
    i = i +% 1;
  }
  return "";
}
// A conservative partial type inference: returns the C++ type of an expr, or "" when unknown.
// "" disables every downstream check (so we never flag valid code we can't fully type).
function envType(env: &Vec<Param>, name: str): str {
  let i: u32 = env.len;
  while (i > 0) { i = i -% 1; if (env[i].name == name) { return env[i].ty; } }   // innermost binding wins
  return "";
}
function envIndex(env: &Vec<Param>, name: str): u32 {   // index of the innermost binding, or env.len if absent
  let i: u32 = env.len;
  while (i > 0) { i = i -% 1; if (env[i].name == name) { return i; } }
  return env.len;
}
function isCopy(ty: str): bool {   // scalars copy; structs/strings/containers/optionals move
  return ty == "int8_t" || ty == "int16_t" || ty == "int32_t" || ty == "int64_t" || ty == "__int128"
      || ty == "uint8_t" || ty == "uint16_t" || ty == "uint32_t" || ty == "uint64_t" || ty == "unsigned __int128"
      || ty == "bool" || ty == "char32_t" || ty == "float" || ty == "double" || ty == "_Float16";
}
function removeName(v: &mut Vec<str>, name: str) {   // drop name from the moved-set (reassignment revives it)
  let i: u32 = 0;
  while (i < v.len) { if (v[i] == name) { v[i] = ""; } i = i +% 1; }   // tombstone (contains() ignores "")
}
function typeOf(e: &Expr, env: &Vec<Param>): str {
  match e {
    Num(v) => { return "int32_t"; }
    FloatLit(s) => { return "double"; }
    BoolLit(b) => { return "bool"; }
    StrLit(s) => { return "std::u32string"; }
    CharLit(c) => { return "char32_t"; }
    Var(n) => { return envType(env, n); }
    Not(x) => { return "bool"; }
    Some(x) => { return "opt"; }
    NoneLit => { return "opt"; }
    TryCast(x, t) => { return "opt"; }
    Cast(x, t) => { return t; }
    Bin(op, l, r) => {
      if (op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">=" || op == "&&" || op == "||") { return "bool"; }
      return typeOf(l.get(), env);
    }
    Comptime(x) => { return typeOf(x.get(), env); }
    _ => { return ""; }
  }
}
function isUserStruct(structs: &Vec<StructDef>, ty: str): bool {
  let i: u32 = 0;
  while (i < structs.len) { if (structs[i].name == ty) { return true; } i = i +% 1; }
  return false;
}
function baseVar(e: &Expr): str {   // the root variable of a place expression
  match e { Var(n) => { return n; } Field(o, f) => { return baseVar(o.get()); } Index(o, ix) => { return baseVar(o.get()); } _ => { return ""; } }
}
function baseName(ty: str): str {   // "Cell<int32_t>" -> "Cell"
  let i: u32 = 0;
  while (i < ty.len) { if (ty[i] == '<') { return substr(ty, 0, i); } i = i +% 1; }
  return ty;
}
function methodIsMut(structs: &Vec<StructDef>, sname: str, m: str): bool {
  let i: u32 = 0;
  while (i < structs.len) {
    if (structs[i].name == sname) {
      let mi: u32 = 0;
      while (mi < structs[i].methods.len) { if (structs[i].methods[mi].name == m) { return structs[i].methods[mi].isMut; } mi = mi +% 1; }
    }
    i = i +% 1;
  }
  return false;
}
// A comptime expression may only read compile-time values: literals, function calls, top-level consts,
// or local `const` bindings — never a runtime local/param (a non-const binding in scope).
function comptimeCheck(e: &Expr, env: &Vec<Param>, consts: &Vec<str>): str {
  match e {
    Var(n) => { if (envType(env, n) != "" && !contains(consts, n)) { return `'${n}' is not a compile-time value`; } }
    Bin(op, l, r) => { let a: str = comptimeCheck(l.get(), env, consts); if (a != "") { return a; } return comptimeCheck(r.get(), env, consts); }
    Not(x) => { return comptimeCheck(x.get(), env, consts); }
    Field(o, f) => { return comptimeCheck(o.get(), env, consts); }
    Index(o, ix) => { let a: str = comptimeCheck(o.get(), env, consts); if (a != "") { return a; } return comptimeCheck(ix.get(), env, consts); }
    Cast(x, t) => { return comptimeCheck(x.get(), env, consts); }
    Call(n, args) => { let i: u32 = 0; while (i < args.len) { let z: str = comptimeCheck(args[i].get(), env, consts); if (z != "") { return z; } i = i +% 1; } }
    _ => { }
  }
  return "";
}
// Reject mutating a const binding: `&mut c` and `c.mutMethod(...)` where c was declared `const`.
function checkConstMutExpr(e: &Expr, env: &Vec<Param>, consts: &Vec<str>, structs: &Vec<StructDef>): str {
  match e {
    Borrow(bm, inner) => {
      if (bm) { let bv: str = baseVar(inner.get()); if (bv != "" && contains(consts, bv)) { return `cannot take '&mut ${bv}': it is a const binding`; } }
      return checkConstMutExpr(inner.get(), env, consts, structs);
    }
    MethodCall(o, m, args) => {
      match o.get() {
        Var(c) => { if (contains(consts, c) && methodIsMut(structs, baseName(envType(env, c)), m)) { return `'${m}' needs &mut self but '${c}' is immutable`; } }
        _ => { }
      }
      let a: str = checkConstMutExpr(o.get(), env, consts, structs); if (a != "") { return a; }
      let i: u32 = 0; while (i < args.len) { let z: str = checkConstMutExpr(args[i].get(), env, consts, structs); if (z != "") { return z; } i = i +% 1; }
    }
    Call(n, args) => { let i: u32 = 0; while (i < args.len) { let z: str = checkConstMutExpr(args[i].get(), env, consts, structs); if (z != "") { return z; } i = i +% 1; } }
    Bin(op, l, r) => { let a: str = checkConstMutExpr(l.get(), env, consts, structs); if (a != "") { return a; } return checkConstMutExpr(r.get(), env, consts, structs); }
    Not(x) => { return checkConstMutExpr(x.get(), env, consts, structs); }
    Field(o, f) => { return checkConstMutExpr(o.get(), env, consts, structs); }
    Index(o, ix) => { let a: str = checkConstMutExpr(o.get(), env, consts, structs); if (a != "") { return a; } return checkConstMutExpr(ix.get(), env, consts, structs); }
    Some(x) => { return checkConstMutExpr(x.get(), env, consts, structs); }
    OkE(x) => { return checkConstMutExpr(x.get(), env, consts, structs); }
    ErrE(x) => { return checkConstMutExpr(x.get(), env, consts, structs); }
    OrElse(a2, b2) => { let a: str = checkConstMutExpr(a2.get(), env, consts, structs); if (a != "") { return a; } return checkConstMutExpr(b2.get(), env, consts, structs); }
    Cast(x, t) => { return checkConstMutExpr(x.get(), env, consts, structs); }
    TryQ(x) => { return checkConstMutExpr(x.get(), env, consts, structs); }
    Comptime(x) => { let r: str = comptimeCheck(x.get(), env, consts); if (r != "") { return r; } return checkConstMutExpr(x.get(), env, consts, structs); }
    Template(strs, exprs) => { let i: u32 = 0; while (i < exprs.len) { let z: str = checkConstMutExpr(exprs[i].get(), env, consts, structs); if (z != "") { return z; } i = i +% 1; } }
    ArrLit(els) => { let i: u32 = 0; while (i < els.len) { let z: str = checkConstMutExpr(els[i].get(), env, consts, structs); if (z != "") { return z; } i = i +% 1; } }
    StructLit(n, vals) => { let i: u32 = 0; while (i < vals.len) { let z: str = checkConstMutExpr(vals[i].get(), env, consts, structs); if (z != "") { return z; } i = i +% 1; } }
    _ => { }
  }
  return "";
}
function checkConstMut(body: &Vec<Stmt>, env: &mut Vec<Param>, consts: &mut Vec<str>, structs: &Vec<StructDef>): str {
  let i: u32 = 0;
  while (i < body.len) {
    match body[i] {
      Let(n, t, v, isConst) => {
        let a: str = checkConstMutExpr(v.get(), env, consts, structs); if (a != "") { return a; }
        env.push(Param { name: n, ty: t });
        if (isConst) { consts.push(n); }
      }
      Assign(tg, v) => { let a: str = checkConstMutExpr(tg.get(), env, consts, structs); if (a != "") { return a; } let b: str = checkConstMutExpr(v.get(), env, consts, structs); if (b != "") { return b; } }
      Ret(v) => { let a: str = checkConstMutExpr(v.get(), env, consts, structs); if (a != "") { return a; } }
      Print(v) => { let a: str = checkConstMutExpr(v.get(), env, consts, structs); if (a != "") { return a; } }
      ExprS(v) => { let a: str = checkConstMutExpr(v.get(), env, consts, structs); if (a != "") { return a; } }
      If(c, then, els) => { let a: str = checkConstMutExpr(c.get(), env, consts, structs); if (a != "") { return a; } let t1: str = checkConstMut(&then, env, consts, structs); if (t1 != "") { return t1; } let t2: str = checkConstMut(&els, env, consts, structs); if (t2 != "") { return t2; } }
      While(c, wb) => { let a: str = checkConstMutExpr(c.get(), env, consts, structs); if (a != "") { return a; } let t: str = checkConstMut(&wb, env, consts, structs); if (t != "") { return t; } }
      ForOf(n, it, fb) => { env.push(Param { name: n, ty: "" }); let t: str = checkConstMut(&fb, env, consts, structs); if (t != "") { return t; } }
      Scope(sb) => { let t: str = checkConstMut(&sb, env, consts, structs); if (t != "") { return t; } }
      Defer(db) => { let t: str = checkConstMut(&db, env, consts, structs); if (t != "") { return t; } }
      Match(sc, arms) => { let a: str = checkConstMutExpr(sc.get(), env, consts, structs); if (a != "") { return a; } let ai: u32 = 0; while (ai < arms.len) { let t: str = checkConstMut(&arms[ai].body, env, consts, structs); if (t != "") { return t; } ai = ai +% 1; } }
      _ => { }
    }
    i = i +% 1;
  }
  return "";
}
// The lvalue path of an expression (Var "p", Field "o.a", Index "a[]"), or "" if not a place.
function lvaluePath(e: &Expr): str {
  match e {
    Var(n) => { return n; }
    Field(o, f) => { let p: str = lvaluePath(o.get()); if (p == "") { return ""; } return p + "." + f; }
    Index(o, ix) => { let p: str = lvaluePath(o.get()); if (p == "") { return ""; } return p + "[]"; }
    _ => { return ""; }
  }
}
// In one call, the same place cannot be borrowed &mut twice, nor both & and &mut (disjoint places are OK).
function checkAliasArgs(args: &Vec<Box<Expr>>): str {
  let paths: Vec<str> = Vec.new();
  let muts: Vec<str> = Vec.new();
  let i: u32 = 0;
  while (i < args.len) {
    match args[i].get() {
      Borrow(bm, inner) => {
        let p: str = lvaluePath(inner.get());
        if (p != "") {
          let j: u32 = 0;
          while (j < paths.len) {
            if (paths[j] == p) {
              let wasMut: bool = (muts[j] == "1");
              if (wasMut && bm) { return "borrowed as &mut more than once"; }
              if (wasMut || bm) { return "borrowed both & and &mut"; }
            }
            j = j +% 1;
          }
          paths.push(p);
          if (bm) { muts.push("1"); } else { muts.push("0"); }
        }
      }
      _ => { }
    }
    i = i +% 1;
  }
  return "";
}
// Recursively check an expression: a moved value cannot be used; logical operands must be bool; atomics
// must not be used as plain values; load() may not take a Release/AcqRel order. Recurses everywhere.
function checkExpr(e: &Expr, env: &Vec<Param>, moved: &Vec<str>): str {
  match e {
    Var(n) => { if (contains(moved, n)) { return "use of moved value"; } }
    Bin(op, l, r) => {
      if (op == "&&" || op == "||") {
        let lt: str = typeOf(l.get(), env);
        let rt: str = typeOf(r.get(), env);
        if (lt != "" && lt != "bool") { return "requires bool operands"; }
        if (rt != "" && rt != "bool") { return "requires bool operands"; }
      } else {
        if (startsWith(typeOf(l.get(), env), "std::atomic") || startsWith(typeOf(r.get(), env), "std::atomic")) { return "Atomic can only be accessed via load/store/fetchAdd/compareExchange"; }
      }
      let a: str = checkExpr(l.get(), env, moved); if (a != "") { return a; }
      return checkExpr(r.get(), env, moved);
    }
    Not(x) => {
      let xt: str = typeOf(x.get(), env);
      if (xt != "" && xt != "bool") { return "requires bool operands"; }
      return checkExpr(x.get(), env, moved);
    }
    MethodCall(o, m, args) => {
      if (m == "load" && args.len >= 1) {
        match args[0].get() { Var(ord) => { if (ord == "Release" || ord == "AcqRel") { return "load's order must be one of Relaxed, Acquire"; } } _ => { } }
      }
      let aa: str = checkAliasArgs(&args); if (aa != "") { return aa; }
      let a: str = checkExpr(o.get(), env, moved); if (a != "") { return a; }
      let i: u32 = 0; while (i < args.len) { let z: str = checkExpr(args[i].get(), env, moved); if (z != "") { return z; } i = i +% 1; }
    }
    Call(n, args) => { let aa: str = checkAliasArgs(&args); if (aa != "") { return aa; } let i: u32 = 0; while (i < args.len) { let z: str = checkExpr(args[i].get(), env, moved); if (z != "") { return z; } i = i +% 1; } }
    Field(o, f) => { return checkExpr(o.get(), env, moved); }
    Index(o, ix) => { let a: str = checkExpr(o.get(), env, moved); if (a != "") { return a; } return checkExpr(ix.get(), env, moved); }
    Borrow(bm, x) => { return checkExpr(x.get(), env, moved); }
    Some(x) => { return checkExpr(x.get(), env, moved); }
    OkE(x) => { return checkExpr(x.get(), env, moved); }
    ErrE(x) => { return checkExpr(x.get(), env, moved); }
    OrElse(a2, b2) => { let a: str = checkExpr(a2.get(), env, moved); if (a != "") { return a; } return checkExpr(b2.get(), env, moved); }
    Cast(x, t) => { return checkExpr(x.get(), env, moved); }
    TryQ(x) => { return checkExpr(x.get(), env, moved); }
    TryCast(x, t) => { return checkExpr(x.get(), env, moved); }
    Comptime(x) => { return checkExpr(x.get(), env, moved); }
    Template(strs, exprs) => { let i: u32 = 0; while (i < exprs.len) { let z: str = checkExpr(exprs[i].get(), env, moved); if (z != "") { return z; } i = i +% 1; } }
    ArrLit(els) => { let i: u32 = 0; while (i < els.len) { let z: str = checkExpr(els[i].get(), env, moved); if (z != "") { return z; } i = i +% 1; } }
    StructLit(n, vals) => { let i: u32 = 0; while (i < vals.len) { let z: str = checkExpr(vals[i].get(), env, moved); if (z != "") { return z; } i = i +% 1; } }
    _ => { }
  }
  return "";
}
// The bare source variable of an expression that constitutes a move (a plain `let q = p`), else "".
function moveSourceVar(e: &Expr): str {
  match e { Var(n) => { return n; } _ => { return ""; } }
}
// Walk a statement list maintaining a per-block moved-set; flag use-after-move and moving an outer
// binding inside a loop. moved-set is local to each block (no leak across branches -> no false positives).
function checkStmtsEnv(body: &Vec<Stmt>, env: &mut Vec<Param>, structs: &Vec<StructDef>, inLoop: bool, loopStart: u32): str {
  let moved: Vec<str> = Vec.new();
  let i: u32 = 0;
  while (i < body.len) {
    match body[i] {
      Let(n, t, v, isConst) => {
        let ce: str = checkExpr(v.get(), env, &moved); if (ce != "") { return ce; }
        if (startsWith(t, "std::optional<")) {                 // no implicit wrap: T? must be init from an optional
          let vt: str = typeOf(v.get(), env);
          if (vt != "" && vt != "opt") { return "cannot init an optional with a non-optional value"; }
        }
        let src: str = moveSourceVar(v.get());                 // `let q = p;` moves a user-struct binding p
        if (src != "" && isUserStruct(structs, envType(env, src))) {
          if (inLoop && envIndex(env, src) < loopStart) { return `cannot move '${src}' inside a loop`; }
          moved.push(src);
        }
        env.push(Param { name: n, ty: t });
      }
      Assign(tg, v) => {
        let b: str = checkExpr(v.get(), env, &moved); if (b != "") { return b; }   // RHS reads first (a moved var here is an error)
        let tn: str = moveSourceVar(tg.get());
        if (tn != "") { removeName(&mut moved, tn); }                               // `p = ...` is a write; reassigning revives p
        else { let a: str = checkExpr(tg.get(), env, &moved); if (a != "") { return a; } }   // a[i] / a.f target: its reads still count
      }
      Ret(v) => { let a: str = checkExpr(v.get(), env, &moved); if (a != "") { return a; } }
      Print(v) => { let a: str = checkExpr(v.get(), env, &moved); if (a != "") { return a; } }
      ExprS(v) => { let a: str = checkExpr(v.get(), env, &moved); if (a != "") { return a; } }
      If(c, then, els) => {
        let a: str = checkExpr(c.get(), env, &moved); if (a != "") { return a; }
        let t1: str = checkStmtsEnv(&then, env, structs, inLoop, loopStart); if (t1 != "") { return t1; }
        let t2: str = checkStmtsEnv(&els, env, structs, inLoop, loopStart); if (t2 != "") { return t2; }
      }
      While(c, wb) => {
        let a: str = checkExpr(c.get(), env, &moved); if (a != "") { return a; }
        let t: str = checkStmtsEnv(&wb, env, structs, true, env.len); if (t != "") { return t; }
      }
      ForOf(n, it, fb) => { env.push(Param { name: n, ty: "" }); let t: str = checkStmtsEnv(&fb, env, structs, true, env.len); if (t != "") { return t; } }
      Scope(sb) => { let t: str = checkStmtsEnv(&sb, env, structs, inLoop, loopStart); if (t != "") { return t; } }
      Defer(db) => { let t: str = checkStmtsEnv(&db, env, structs, inLoop, loopStart); if (t != "") { return t; } }
      Match(sc, arms) => { let a: str = checkExpr(sc.get(), env, &moved); if (a != "") { return a; } let ai: u32 = 0; while (ai < arms.len) { let t: str = checkStmtsEnv(&arms[ai].body, env, structs, inLoop, loopStart); if (t != "") { return t; } ai = ai +% 1; } }
      _ => { }
    }
    i = i +% 1;
  }
  return "";
}
// For a function that RETURNS a reference or slice: returning `&local`, `slice(x)`, or a local
// reference-binding would dangle. (Only invoked for ref/slice-returning fns, so value-returning code —
// including all positives and mozc itself — is never touched.)
function isSliceCall(e: &Expr): bool {
  match e { Call(n, a) => { return n == "slice"; } _ => { return false; } }
}
function checkEscapeBody(body: &Vec<Stmt>, localRefs: &mut Vec<str>): str {
  let i: u32 = 0;
  while (i < body.len) {
    match body[i] {
      Let(n, t, v, c) => {
        let isRef: bool = (t.len > 0 && t[t.len -% 1] == '&');
        match v.get() { Borrow(bm, b) => { isRef = true; } _ => { } }
        if (isSliceCall(v.get())) { isRef = true; }
        if (isRef) { localRefs.push(n); }
      }
      Ret(v) => {
        match v.get() {
          Borrow(bm, b) => { return "reference/slice to local data"; }
          Var(r) => { if (contains(localRefs, r)) { return "reference/slice to local data"; } }
          _ => { if (isSliceCall(v.get())) { return "reference/slice to local data"; } }
        }
      }
      If(c, then, els) => { let a: str = checkEscapeBody(&then, localRefs); if (a != "") { return a; } let b: str = checkEscapeBody(&els, localRefs); if (b != "") { return b; } }
      While(c, wb) => { let e: str = checkEscapeBody(&wb, localRefs); if (e != "") { return e; } }
      ForOf(n, it, fb) => { let e: str = checkEscapeBody(&fb, localRefs); if (e != "") { return e; } }
      Scope(sb) => { let e: str = checkEscapeBody(&sb, localRefs); if (e != "") { return e; } }
      Match(sc, arms) => { let ai: u32 = 0; while (ai < arms.len) { let e: str = checkEscapeBody(&arms[ai].body, localRefs); if (e != "") { return e; } ai = ai +% 1; } }
      _ => { }
    }
    i = i +% 1;
  }
  return "";
}
// Does the variable `name` appear anywhere in an expression?
function exprMentions(e: &Expr, name: str): bool {
  match e {
    Var(n) => { return n == name; }
    Bin(op, l, r) => { return exprMentions(l.get(), name) || exprMentions(r.get(), name); }
    Not(x) => { return exprMentions(x.get(), name); }
    Field(o, f) => { return exprMentions(o.get(), name); }
    Index(o, ix) => { return exprMentions(o.get(), name) || exprMentions(ix.get(), name); }
    Borrow(bm, x) => { return exprMentions(x.get(), name); }
    MethodCall(o, m, args) => { if (exprMentions(o.get(), name)) { return true; } let i: u32 = 0; while (i < args.len) { if (exprMentions(args[i].get(), name)) { return true; } i = i +% 1; } return false; }
    Call(n2, args) => { let i: u32 = 0; while (i < args.len) { if (exprMentions(args[i].get(), name)) { return true; } i = i +% 1; } return false; }
    Some(x) => { return exprMentions(x.get(), name); }
    OkE(x) => { return exprMentions(x.get(), name); }
    ErrE(x) => { return exprMentions(x.get(), name); }
    OrElse(a, b) => { return exprMentions(a.get(), name) || exprMentions(b.get(), name); }
    Cast(x, t) => { return exprMentions(x.get(), name); }
    TryQ(x) => { return exprMentions(x.get(), name); }
    TryCast(x, t) => { return exprMentions(x.get(), name); }
    Comptime(x) => { return exprMentions(x.get(), name); }
    Template(strs, ex) => { let i: u32 = 0; while (i < ex.len) { if (exprMentions(ex[i].get(), name)) { return true; } i = i +% 1; } return false; }
    ArrLit(els) => { let i: u32 = 0; while (i < els.len) { if (exprMentions(els[i].get(), name)) { return true; } i = i +% 1; } return false; }
    StructLit(n2, vals) => { let i: u32 = 0; while (i < vals.len) { if (exprMentions(vals[i].get(), name)) { return true; } i = i +% 1; } return false; }
    SpawnExpr(fn, sa) => { let i: u32 = 0; while (i < sa.len) { if (exprMentions(sa[i].get(), name)) { return true; } i = i +% 1; } return false; }
    _ => { return false; }
  }
}
function stmtMentions(s: &Stmt, name: str): bool {
  match s {
    Let(n, t, v, c) => { return exprMentions(v.get(), name); }
    Assign(tg, v) => { return exprMentions(tg.get(), name) || exprMentions(v.get(), name); }
    Ret(v) => { return exprMentions(v.get(), name); }
    Print(v) => { return exprMentions(v.get(), name); }
    ExprS(v) => { return exprMentions(v.get(), name); }
    If(c, t, e) => { return exprMentions(c.get(), name); }
    While(c, b) => { return exprMentions(c.get(), name); }
    _ => { return false; }
  }
}
// A stored exclusive borrow: `let r = &mut c` (a Borrow) or `let job = dev.launch(... &mut x ...)`.
// Helpers return the holder/value/kind by VALUE (no move of the match binding).
function borrowMutArg(args: &Vec<Box<Expr>>): str {   // first &mut arg's base value, else ""
  let ai: u32 = 0;
  while (ai < args.len) { match args[ai].get() { Borrow(bm, inn) => { if (bm) { return baseVar(inn.get()); } } _ => { } } ai = ai +% 1; }
  return "";
}
function borrowHolder(s: &Stmt): str {
  match s {
    Let(n, t, v, c) => {
      match v.get() {
        Borrow(bm, inner) => { if (bm) { return n; } }
        MethodCall(o, m, args) => { if (m == "launch" && borrowMutArg(&args) != "") { return n; } }
        _ => { }
      }
    }
    _ => { }
  }
  return "";
}
function borrowedValue(s: &Stmt): str {
  match s {
    Let(n, t, v, c) => {
      match v.get() {
        Borrow(bm, inner) => { if (bm) { return baseVar(inner.get()); } }
        MethodCall(o, m, args) => { if (m == "launch") { return borrowMutArg(&args); } }
        _ => { }
      }
    }
    _ => { }
  }
  return "";
}
function borrowIsLaunch(s: &Stmt): bool {
  match s {
    Let(n, t, v, c) => { match v.get() { MethodCall(o, m, args) => { if (m == "launch" && borrowMutArg(&args) != "") { return true; } } _ => { } } }
    _ => { }
  }
  return false;
}
// borrow=exclusive: a value touched while it is exclusively borrowed is an error. The borrow is held by
// a stored `let r = &mut c` (until r's last use) or by `let job = dev.launch(... &mut x ...)` (until
// job.await()). Linear per statement-list; recurses into nested blocks.
function checkBorrowLiveness(body: &Vec<Stmt>): str {
  let i: u32 = 0;
  while (i < body.len) {
    let rvar: str = borrowHolder(&body[i]);
    let bvar: str = borrowedValue(&body[i]);
    let isLaunch: bool = borrowIsLaunch(&body[i]);
    if (bvar != "" && rvar != "") {
      let endIdx: u32 = i +% 1;
      if (isLaunch) {                                // borrow ends at job.await()
        let k: u32 = i +% 1;
        endIdx = body.len;
        let done: bool = false;
        while (k < body.len && !done) {
          match body[k] { ExprS(v) => { match v.get() { MethodCall(o, m, a) => { match o.get() { Var(jn) => { if (jn == rvar && m == "await") { endIdx = k; done = true; } } _ => { } } } _ => { } } } _ => { } }
          k = k +% 1;
        }
      } else {                                        // borrow ends at the ref's last use (NLL)
        let k: u32 = i +% 1;
        while (k < body.len) { if (stmtMentions(&body[k], rvar)) { endIdx = k +% 1; } k = k +% 1; }
      }
      let j: u32 = i +% 1;
      while (j < endIdx) {
        if (stmtMentions(&body[j], bvar)) {
          if (isLaunch) { return "exclusively borrowed"; }
          return "while it is mutably borrowed";
        }
        j = j +% 1;
      }
    }
    match body[i] {                                   // recurse into nested blocks
      If(c, then, els) => { let a: str = checkBorrowLiveness(&then); if (a != "") { return a; } let b: str = checkBorrowLiveness(&els); if (b != "") { return b; } }
      While(c, wb) => { let a: str = checkBorrowLiveness(&wb); if (a != "") { return a; } }
      ForOf(n, it, fb) => { let a: str = checkBorrowLiveness(&fb); if (a != "") { return a; } }
      Scope(sb) => { let a: str = checkBorrowLiveness(&sb); if (a != "") { return a; } }
      Match(sc, arms) => { let ai: u32 = 0; while (ai < arms.len) { let a: str = checkBorrowLiveness(&arms[ai].body); if (a != "") { return a; } ai = ai +% 1; } }
      _ => { }
    }
    i = i +% 1;
  }
  return "";
}
// A spawn target may not receive a reference to a non-Sync value (it would cross a thread boundary).
function checkSpawnArgs(args: &Vec<Box<Expr>>, env: &Vec<Param>, structs: &Vec<StructDef>): str {
  let i: u32 = 0;
  while (i < args.len) {
    match args[i].get() {
      Borrow(bm, inner) => {
        let ty: str = envType(env, baseVar(inner.get()));
        if (ty != "" && !isSyncType(ty) && !structIsSync(structs, ty)) { return "cannot cross a thread boundary"; }
      }
      _ => { }
    }
    i = i +% 1;
  }
  return "";
}
function isTaskType(t: str): bool { return t == "std::thread" || startsWith(t, "mz::JoinFuture"); }
// Collect names of Tasks that are joined — t.join() anywhere in an expression (e.g. `let r = t.join()`).
function exprJoins(e: &Expr, joined: &mut Vec<str>) {
  match e {
    MethodCall(o, m, args) => {
      if (m == "join") { match o.get() { Var(t) => { joined.push(t); } _ => { } } }
      exprJoins(o.get(), joined);
      let i: u32 = 0; while (i < args.len) { exprJoins(args[i].get(), joined); i = i +% 1; }
    }
    Bin(op, l, r) => { exprJoins(l.get(), joined); exprJoins(r.get(), joined); }
    Not(x) => { exprJoins(x.get(), joined); }
    Field(o, f) => { exprJoins(o.get(), joined); }
    Index(o, ix) => { exprJoins(o.get(), joined); exprJoins(ix.get(), joined); }
    Borrow(bm, x) => { exprJoins(x.get(), joined); }
    Call(n, args) => { let i: u32 = 0; while (i < args.len) { exprJoins(args[i].get(), joined); i = i +% 1; } }
    Some(x) => { exprJoins(x.get(), joined); }
    OkE(x) => { exprJoins(x.get(), joined); }
    ErrE(x) => { exprJoins(x.get(), joined); }
    OrElse(a, b) => { exprJoins(a.get(), joined); exprJoins(b.get(), joined); }
    Cast(x, t) => { exprJoins(x.get(), joined); }
    TryQ(x) => { exprJoins(x.get(), joined); }
    Comptime(x) => { exprJoins(x.get(), joined); }
    Template(strs, ex) => { let i: u32 = 0; while (i < ex.len) { exprJoins(ex[i].get(), joined); i = i +% 1; } }
    _ => { }
  }
}
function collectJoined(body: &Vec<Stmt>, joined: &mut Vec<str>) {
  let i: u32 = 0;
  while (i < body.len) {
    match body[i] {
      Let(n, t, v, c) => { exprJoins(v.get(), joined); }
      Assign(tg, v) => { exprJoins(v.get(), joined); }
      Ret(v) => { exprJoins(v.get(), joined); }
      Print(v) => { exprJoins(v.get(), joined); }
      ExprS(v) => { exprJoins(v.get(), joined); }
      If(c, then, els) => { collectJoined(&then, joined); collectJoined(&els, joined); }
      While(c, wb) => { collectJoined(&wb, joined); }
      ForOf(n, it, fb) => { collectJoined(&fb, joined); }
      Scope(sb) => { collectJoined(&sb, joined); }
      Defer(db) => { collectJoined(&db, joined); }
      Match(sc, arms) => { let ai: u32 = 0; while (ai < arms.len) { collectJoined(&arms[ai].body, joined); ai = ai +% 1; } }
      _ => { }
    }
    i = i +% 1;
  }
}
// Check spawns: a non-Sync reference may not cross a thread, and a named Task must be joined.
function checkSpawnTasks(body: &Vec<Stmt>, env: &mut Vec<Param>, joined: &Vec<str>, structs: &Vec<StructDef>): str {
  let i: u32 = 0;
  while (i < body.len) {
    match body[i] {
      Let(n, t, v, c) => {
        match v.get() {
          SpawnExpr(fn, sa) => {
            let s: str = checkSpawnArgs(&sa, env, structs); if (s != "") { return s; }
            if (isTaskType(t) && !contains(joined, n)) { return `'${n}' is a Task that was never joined`; }
          }
          _ => { }
        }
        env.push(Param { name: n, ty: t });
      }
      ExprS(v) => { match v.get() { SpawnExpr(fn, sa) => { let s: str = checkSpawnArgs(&sa, env, structs); if (s != "") { return s; } } _ => { } } }
      If(c, then, els) => { let t1: str = checkSpawnTasks(&then, env, joined, structs); if (t1 != "") { return t1; } let t2: str = checkSpawnTasks(&els, env, joined, structs); if (t2 != "") { return t2; } }
      While(c, wb) => { let t: str = checkSpawnTasks(&wb, env, joined, structs); if (t != "") { return t; } }
      ForOf(n, it, fb) => { env.push(Param { name: n, ty: "" }); let t: str = checkSpawnTasks(&fb, env, joined, structs); if (t != "") { return t; } }
      Scope(sb) => { let t: str = checkSpawnTasks(&sb, env, joined, structs); if (t != "") { return t; } }
      Defer(db) => { let t: str = checkSpawnTasks(&db, env, joined, structs); if (t != "") { return t; } }
      Match(sc, arms) => { let ai: u32 = 0; while (ai < arms.len) { let t: str = checkSpawnTasks(&arms[ai].body, env, joined, structs); if (t != "") { return t; } ai = ai +% 1; } }
      _ => { }
    }
    i = i +% 1;
  }
  return "";
}
// A kernel may not get the same buffer for two parameters (distinct names = distinct objects = no
// aliasing), which lets the emitter mark every kernel Buffer param __restrict.
function launchArgName(e: &Expr): str {
  match e { Borrow(bm, inner) => { return baseVar(inner.get()); } _ => { return baseVar(e); } }
}
function launchAliasErr(kname: str, args: &Vec<Box<Expr>>, funcs: &Vec<Func>): str {
  let kidx: u32 = funcs.len;
  let ki: u32 = 0;
  while (ki < funcs.len) { if (funcs[ki].isKernel && funcs[ki].name == kname) { kidx = ki; } ki = ki +% 1; }
  if (kidx >= funcs.len) { return ""; }
  let seen: Vec<str> = Vec.new();
  let k: u32 = 0;
  while (k < funcs[kidx].params.len && 2 +% k < args.len) {
    if (startsWith(funcs[kidx].params[k].ty, "mz::Buffer")) {
      let nm: str = launchArgName(args[2 +% k].get());
      if (nm != "") {
        if (contains(&seen, nm)) { return `launch '${kname}': buffer '${nm}' passed for more than one parameter`; }
        seen.push(nm);
      }
    }
    k = k +% 1;
  }
  return "";
}
function launchInExpr(e: &Expr, funcs: &Vec<Func>): str {
  match e {
    Call(n, args) => { if (n == "launch" && args.len > 0) { return launchAliasErr(varName(args[0].get()), &args, funcs); } }
    MethodCall(o, m, args) => { if (m == "launch" && args.len > 0) { return launchAliasErr(varName(args[0].get()), &args, funcs); } }
    _ => { }
  }
  return "";
}
function checkLaunchStmts(body: &Vec<Stmt>, funcs: &Vec<Func>): str {
  let i: u32 = 0;
  while (i < body.len) {
    match body[i] {
      Let(n, t, v, c) => { let e: str = launchInExpr(v.get(), funcs); if (e != "") { return e; } }
      ExprS(v) => { let e: str = launchInExpr(v.get(), funcs); if (e != "") { return e; } }
      If(c, then, els) => { let a: str = checkLaunchStmts(&then, funcs); if (a != "") { return a; } let b: str = checkLaunchStmts(&els, funcs); if (b != "") { return b; } }
      While(c, wb) => { let a: str = checkLaunchStmts(&wb, funcs); if (a != "") { return a; } }
      ForOf(n, it, fb) => { let a: str = checkLaunchStmts(&fb, funcs); if (a != "") { return a; } }
      Scope(sb) => { let a: str = checkLaunchStmts(&sb, funcs); if (a != "") { return a; } }
      Defer(db) => { let a: str = checkLaunchStmts(&db, funcs); if (a != "") { return a; } }
      Match(sc, arms) => { let ai: u32 = 0; while (ai < arms.len) { let a: str = checkLaunchStmts(&arms[ai].body, funcs); if (a != "") { return a; } ai = ai +% 1; } }
      _ => { }
    }
    i = i +% 1;
  }
  return "";
}
function checkProgram(funcs: &Vec<Func>, structs: &Vec<StructDef>, enums: &Vec<EnumDef>): str {
  let ei: u32 = 0;
  while (ei < enums.len) {                          // Ok/Err are reserved for Result
    let vi: u32 = 0;
    while (vi < enums[ei].variants.len) {
      let vn: str = enums[ei].variants[vi].name;
      if (vn == "Ok" || vn == "Err") { return `'${vn}' is reserved for Result`; }
      vi = vi +% 1;
    }
    ei = ei +% 1;
  }
  let fi: u32 = 0;
  while (fi < funcs.len) {
    if (containsSub(funcs[fi].ret, "std::atomic")) { return "cannot return an atomic-containing type by value"; }
    let pi: u32 = 0;
    while (pi < funcs[fi].params.len) {
      let pt: str = funcs[fi].params[pi].ty;
      let te: str = checkTypeStr(pt);
      if (te != "") { return te; }
      if (funcs[fi].isKernel) {
        if (startsWith(pt, "std::array") || startsWith(pt, "mz::Slice")) { return "cannot be an array/slice"; }
        if (containsSub(pt, "atomic")) { return "Atomic is not supported inside a kernel"; }
      }
      pi = pi +% 1;
    }
    let be: str = checkBodyTypes(&funcs[fi].body);
    if (be != "") { return be; }
    let pe: Vec<Param> = Vec.new();                 // seed the env with the params, then walk the body
    let pj: u32 = 0;
    while (pj < funcs[fi].params.len) { pe.push(Param { name: funcs[fi].params[pj].name, ty: funcs[fi].params[pj].ty }); pj = pj +% 1; }
    let bce: str = checkStmtsEnv(&funcs[fi].body, &mut pe, structs, false, 0);
    if (bce != "") { return bce; }
    let ce2: Vec<Param> = Vec.new();
    let pk: u32 = 0;
    while (pk < funcs[fi].params.len) { ce2.push(Param { name: funcs[fi].params[pk].name, ty: funcs[fi].params[pk].ty }); pk = pk +% 1; }
    let consts: Vec<str> = Vec.new();
    let cm: str = checkConstMut(&funcs[fi].body, &mut ce2, &mut consts, structs);
    if (cm != "") { return cm; }
    let joined: Vec<str> = Vec.new();
    collectJoined(&funcs[fi].body, &mut joined);
    let se: Vec<Param> = Vec.new();
    let pm: u32 = 0;
    while (pm < funcs[fi].params.len) { se.push(Param { name: funcs[fi].params[pm].name, ty: funcs[fi].params[pm].ty }); pm = pm +% 1; }
    let st: str = checkSpawnTasks(&funcs[fi].body, &mut se, &joined, structs);
    if (st != "") { return st; }
    let bl: str = checkBorrowLiveness(&funcs[fi].body);
    if (bl != "") { return bl; }
    let le: str = checkLaunchStmts(&funcs[fi].body, funcs);   // kernel buffer args must be distinct (sound __restrict)
    if (le != "") { return le; }
    let rt: str = funcs[fi].ret;
    if ((rt.len > 0 && rt[rt.len -% 1] == '&') || startsWith(rt, "mz::Slice")) {   // returns a reference/slice
      let lr: Vec<str> = Vec.new();
      let esc: str = checkEscapeBody(&funcs[fi].body, &mut lr);
      if (esc != "") { return esc; }
    }
    fi = fi +% 1;
  }
  let si: u32 = 0;
  while (si < structs.len) {
    let sf: u32 = 0;
    while (sf < structs[si].fields.len) {
      let te2: str = checkTypeStr(structs[si].fields[sf].ty);
      if (te2 != "") { return te2; }
      sf = sf +% 1;
    }
    si = si +% 1;
  }
  return "";
}
function main() {
  let raw: str = stdin.readAll();
  let seen: Vec<str> = Vec.new();
  let src: str = resolveImports(raw, "", &mut seen);   // expand `import "p";` (paths relative to the importing file's dir)
  let p: Parser = Parser { toks: lex(src), pos: 0, structs: Vec.new(), enums: Vec.new(), consts: Vec.new(), noStruct: false };
  let funcs: Vec<Func> = p.parseProgram();
  let cerr: str = checkProgram(&funcs, &p.structs, &p.enums);   // reject structurally-invalid programs
  if (cerr != "") { abort(cerr); }
  let out: str = "#include \"mozaic_rt.h\"\n\n";   // runtime brings cstdint/iostream/string/array + mz::Vec/Box/Map
  // forward-declare all user types (so mutually-recursive structs/enums via Box/Vec fields resolve)
  let fe: u32 = 0;
  while (fe < p.enums.len) { out = out + `struct ${p.enums[fe].name};\n`; fe = fe +% 1; }
  let fs: u32 = 0;
  while (fs < p.structs.len) { if (p.structs[fs].tparams.len == 0) { out = out + `struct ${p.structs[fs].name};\n`; } fs = fs +% 1; }   // templates can't be plain-forward-declared
  out = out + "\n";
  // enum + struct definitions, then top-level consts, then function prototypes, then bodies.
  let e: u32 = 0;
  while (e < p.enums.len) { out = out + emitEnum(&p.enums[e]); e = e +% 1; }
  let s: u32 = 0;
  while (s < p.structs.len) { out = out + emitStruct(&p.structs[s], &p.enums, &p.structs); s = s +% 1; }
  out = out + "\n";
  // non-generic prototypes FIRST, so a comptime const initializer (e.g. const SQ = squares()) can call them.
  let i: u32 = 0;
  while (i < funcs.len) { if (funcs[i].name != "main" && funcs[i].tparams.len == 0) { out = out + emitProto(&funcs[i], &p.structs); } i = i +% 1; }
  // workgroup wrapper prototypes (definitions come after the kernel bodies; main calls these)
  let wp: u32 = 0;
  while (wp < funcs.len) {
    if (funcs[wp].isKernel && collectShared(&funcs[wp].body).len > 0) {
      let pl: str = paramList(&funcs[wp], &p.structs, false);
      if (pl == "") { out = out + `void _wg_${funcs[wp].name}(mz::Grid);\n`; }
      else { out = out + `void _wg_${funcs[wp].name}(mz::Grid, ${pl});\n`; }
    }
    wp = wp +% 1;
  }
  out = out + "\n";
  let ci: u32 = 0;
  while (ci < p.consts.len) { out = out + `static const ${p.consts[ci].ty} ${p.consts[ci].name} = ${emitExpr(p.consts[ci].value.get(), &p.enums)};\n`; ci = ci +% 1; }
  out = out + "\n";
  let gj: u32 = 0;
  while (gj < funcs.len) { if (funcs[gj].tparams.len > 0) { out = out + emitFunc(&funcs[gj], &p.enums, &p.structs); out = out + "\n"; } gj = gj +% 1; }
  let mj: u32 = 0;
  while (mj < p.structs.len) { out = out + emitMethodDefs(&p.structs[mj], &p.enums, &p.structs); mj = mj +% 1; }
  out = out + "\n";
  let j: u32 = 0;
  while (j < funcs.len) { if (funcs[j].tparams.len == 0) { out = out + emitFunc(&funcs[j], &p.enums, &p.structs); out = out + "\n"; } j = j +% 1; }
  // workgroup-kernel host wrappers (_wg_*), emitted after the kernel bodies they dispatch.
  let wj: u32 = 0;
  while (wj < funcs.len) { if (funcs[wj].isKernel && collectShared(&funcs[wj].body).len > 0) { out = out + emitWgWrapper(&funcs[wj], &p.structs); } wj = wj +% 1; }
  stdout.println(out);
}
