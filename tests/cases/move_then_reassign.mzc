// Positive: move p into q, then reassign p (revives it), then use both.
struct Point { x: i32; y: i32; }
function main() {
  let p: Point = Point { x: 3, y: 4 };
  let q: Point = p;            // moves p
  p = Point { x: 5, y: 6 };    // reassigning revives p
  stdout.println(p.x);         // 5
  stdout.println(q.x);         // 3 (q owns the old value)
}
