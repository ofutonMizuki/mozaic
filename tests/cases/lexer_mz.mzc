// A lexer written IN mozaic — a self-host (M7) stepping stone. Reads source from stdin,
// scans integers / identifiers / single-char operators, collects them in a Vec, and prints
// one token per line. Exercises stdin.readAll, str indexing, char ops, Vec<str>, templates.
function isDigit(c: char): bool { return c >= '0' && c <= '9'; }
function isAlpha(c: char): bool { return (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || c == '_'; }
function isSpace(c: char): bool { return c == ' ' || c == '\n' || c == '\t' || c == '\r'; }

function main() {
  let src: str = stdin.readAll();
  let toks: Vec<str> = Vec.new();
  let i: u32 = 0;
  let n: u32 = src.len;
  while (i < n) {
    let c: char = src[i];
    if (isSpace(c)) {
      i = i +% 1;
    } else if (isDigit(c)) {
      let v: i64 = 0;
      while (i < n && isDigit(src[i])) {
        v = v *% 10 +% ((src[i] as u32) as i64) -% (('0' as u32) as i64);
        i = i +% 1;
      }
      toks.push(`INT ${v}`);
    } else if (isAlpha(c)) {
      let text: str = "";
      while (i < n && (isAlpha(src[i]) || isDigit(src[i]))) {
        text = text + format(src[i]);
        i = i +% 1;
      }
      toks.push(`ID ${text}`);
    } else {
      toks.push(`OP ${c}`);
      i = i +% 1;
    }
  }
  let k: u32 = 0;
  while (k < toks.len) {
    stdout.println(toks[k]);
    k = k +% 1;
  }
}
