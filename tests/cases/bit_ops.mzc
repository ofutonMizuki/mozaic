// Bitwise operators: & | ^ ~ (complement) << >> on integers. C precedence (| < ^ < & < shift),
// signed >> is arithmetic, shifts are checked (trap on out-of-range count in debug). Unsigned ~ wraps.
function main() {
  let a: u32 = 12;                 // 1100
  let b: u32 = 10;                 // 1010
  stdout.println(a & b);           // 8
  stdout.println(a | b);           // 14
  stdout.println(a ^ b);           // 6
  stdout.println(~a);              // 4294967283  (u32 complement)
  stdout.println(a << 2);          // 48
  stdout.println(a >> 1);          // 6
  // precedence
  stdout.println(a | b & 6);       // a | (b&6=2) = 14
  stdout.println(5 ^ 3 & 1);       // 5 ^ (3&1=1) = 4
  stdout.println(1 << 3 | 1);      // (1<<3)|1 = 9
  stdout.println(~a & 255);        // (~12)&255 = 243
  // signed arithmetic right shift
  let s: i32 = 0 - 16;
  stdout.println(s >> 2);          // -4
  // shift/compare precedence: shift binds tighter than ==
  if (1 << 4 == 16) { stdout.println("shift<cmp"); }
}
